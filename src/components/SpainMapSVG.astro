---
import { readFileSync } from 'node:fs';
import path from 'node:path';

const rawSvg = readFileSync(
  path.resolve(process.cwd(), 'public/spain-provinces.svg'),
  'utf-8'
);

const guideIds = new Set(['ES-M', 'ES-B', 'ES-V', 'ES-SE']);

// Make SVG responsive: swap width/height for viewBox + 100% width
let svgContent = rawSvg
  .replace('width="418.45123"', 'class="spain-map-svg" width="100%" viewBox="0 0 418.46 468.64" preserveAspectRatio="xMidYMid meet"')
  .replace('\n   height="468.63733"', '');

// Add class="province-path" (and "has-guide") to every province path by ID
svgContent = svgContent.replace(/id="(ES-[A-Z]+)"/g, (_match, id) => {
  const cls = guideIds.has(id) ? 'province-path has-guide' : 'province-path';
  return `id="${id}" class="${cls}"`;
});
---

<div class="map-container">
  <Fragment set:html={svgContent} />
</div>

<div class="map-legend">
  <div class="legend-grid">
    <span class="legend-dot" style="background:#2D6A4F;"></span><span class="legend-label">北部（ピンチョス・シードル）</span>
    <span class="legend-dot" style="background:#1B4F72;"></span><span class="legend-label">北西部（マリスコ・ワイン）</span>
    <span class="legend-dot" style="background:#795548;"></span><span class="legend-label">中部（アサード・赤ワイン）</span>
    <span class="legend-dot" style="background:#E67E22;"></span><span class="legend-label">東部（パエリア・タパス）</span>
    <span class="legend-dot" style="background:#C0392B;"></span><span class="legend-label">南部（揚げ物・シェリー）</span>
    <span class="legend-dot" style="background:#2E7D32;"></span><span class="legend-label">西部（生ハム・リオハ）</span>
    <span class="legend-dot" style="background:#0277BD;"></span><span class="legend-label">島々（地中海・カナリア）</span>
  </div>
  <p class="legend-note">赤い枠の州 = 編集部グルメガイドあり</p>
</div>

<div id="spain-tooltip" class="province-tooltip" aria-hidden="true"></div>

<style is:global>
  /* Province fill colors by SVG ID */
  #ES-BI, #ES-SS, #ES-VI, #ES-O, #ES-S  { fill: #2D6A4F; }
  #ES-C, #ES-LU, #ES-OR, #ES-PO, #ES-NA { fill: #1B4F72; }
  #ES-M, #ES-BU, #ES-SA, #ES-SG, #ES-VA,
  #ES-AV, #ES-LE, #ES-P, #ES-SO, #ES-ZA,
  #ES-GU, #ES-CR, #ES-CU, #ES-TO, #ES-AB { fill: #795548; }
  #ES-B, #ES-V, #ES-A, #ES-CS,
  #ES-GI, #ES-L, #ES-T              { fill: #E67E22; }
  #ES-SE, #ES-GR, #ES-MA, #ES-CA,
  #ES-CO, #ES-H, #ES-J, #ES-AL, #ES-MU  { fill: #C0392B; }
  #ES-BA, #ES-CC, #ES-LO, #ES-HU,
  #ES-TE, #ES-Z                     { fill: #2E7D32; }
  #ES-GC, #ES-TF, #ES-PM            { fill: #0277BD; }
  #ES-CE, #ES-ML                    { fill: #9ca3af; }

  .province-path {
    stroke: rgba(255, 255, 255, 0.65);
    stroke-width: 0.5;
    cursor: pointer;
    transition: filter 150ms ease;
  }
  .province-path:hover { filter: brightness(1.25); }
  .province-path.has-guide {
    stroke: #C8102E;
    stroke-width: 2;
  }

  #divider { pointer-events: none; }

  .province-tooltip {
    position: fixed;
    z-index: 9999;
    background: #002147;
    border: 1.5px solid #C8102E;
    border-radius: 8px;
    padding: 10px 14px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 150ms ease;
    min-width: 140px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  }
  .province-tooltip.visible { opacity: 1; }
  .tooltip-name {
    font-weight: 700;
    font-size: 14px;
    color: white;
    margin: 0 0 6px;
  }
  .tooltip-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    border-radius: 4px;
    padding: 2px 8px;
  }
  .tooltip-badge--guide { background: #C8102E; color: white; }
  .tooltip-badge--map   { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.85); }
</style>

<style>
  .map-container {
    background: #FAFAF8;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 16px;
    max-width: 800px;
    margin: 0 auto;
  }
  .map-legend {
    margin-top: 20px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  .legend-grid {
    display: grid;
    grid-template-columns: auto 1fr auto 1fr;
    gap: 6px 16px;
    align-items: center;
    margin-bottom: 10px;
  }
  .legend-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  .legend-label { font-size: 12px; color: #6b7280; }
  .legend-note {
    font-size: 12px;
    color: #6b7280;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .legend-note::before {
    content: '';
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid #C8102E;
    border-radius: 3px;
    flex-shrink: 0;
  }
  @media (max-width: 600px) {
    .legend-grid { grid-template-columns: auto 1fr; }
  }
</style>

