    'ES-ZA': { ja: 'サモラ',         url: 'https://maps.app.goo.gl/ZLUzortYSy5YZtZx7',  hasGuide: false },
  };

  var tooltip = document.getElementById('spain-tooltip');
  if (!tooltip) return;

  function showTooltip(e, data) {
    tooltip.innerHTML =
      '<p class="tooltip-name">' + data.ja + '</p>' +
      (data.hasGuide
        ? '<span class="tooltip-badge tooltip-badge--guide">グルメガイドあり</span><span class="tooltip-action">クリックして読む →</span>'
        : '<span class="tooltip-badge tooltip-badge--map">マップを見る →</span>');
    tooltip.classList.add('visible');
    moveTooltip(e);
  }

  function moveTooltip(e) {
    var x = e.clientX + 14;
    var y = e.clientY - 36;
    var tw = tooltip.offsetWidth || 160;
    if (x + tw > window.innerWidth - 8) { x = e.clientX - tw - 8; }
    tooltip.style.left = x + 'px';
    tooltip.style.top = y + 'px';
  }

  function hideTooltip() { tooltip.classList.remove('visible'); }

  document.querySelectorAll('[data-province]').forEach(function (path) {
    var id = path.id;
    var data = provinceMap[id];
    if (!data) return;
    path.addEventListener('mouseenter', function (e) { showTooltip(e, data); });
    path.addEventListener('mousemove', moveTooltip);
    path.addEventListener('mouseleave', hideTooltip);
    path.addEventListener('click', function () {
      hideTooltip();
      if (data.url.startsWith('http')) {
        window.open(data.url, '_blank', 'noopener noreferrer');
      } else {
        window.location.href = data.url;
      }
    });
  });
})();
</script>
