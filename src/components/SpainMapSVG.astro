---

<div class="spain-map-wrap">
  <svg
    viewBox="0 0 900 700"
    xmlns="http://www.w3.org/2000/svg"
    style="width:100%;height:auto;display:block;"
    role="img"
    aria-label="スペイン州別インタラクティブマップ"
  >
    <!-- Ocean background -->
    <rect width="900" height="700" fill="#EBF5FB" rx="8" />

    <!-- Peninsula provinces -->
    {provinces.map((p) => (
      <polygon
        data-province={p.id}
        data-province-ja={p.ja}
        data-url={p.url}
        data-external={p.external ? 'true' : 'false'}
        points={p.points}
        fill={p.color}
        fill-opacity="0.75"
        stroke="white"
        stroke-width="1"
        class={p.hasGuide ? 'province-path has-guide' : 'province-path'}
      />
    ))}

    <!-- Province name labels (major) -->
    <text x="130" y="130" text-anchor="middle" fill="white" font-size="8" font-weight="600" pointer-events="none">GLC</text>
    <text x="290" y="90" text-anchor="middle" fill="white" font-size="8" font-weight="600" pointer-events="none">AST</text>
    <text x="418" y="90" text-anchor="middle" fill="white" font-size="8" font-weight="600" pointer-events="none">CNT</text>
    <text x="471" y="330" text-anchor="middle" fill="white" font-size="9" font-weight="700" pointer-events="none">マドリード</text>
    <text x="700" y="198" text-anchor="middle" fill="white" font-size="9" font-weight="700" pointer-events="none">BCN</text>
    <text x="247" y="600" text-anchor="middle" fill="white" font-size="9" font-weight="700" pointer-events="none">セビリア</text>
    <text x="500" y="515" text-anchor="middle" fill="white" font-size="8" font-weight="600" pointer-events="none">JAN</text>

    <!-- Islas Baleares (Mediterranean inset) -->
    <g>
      <rect x="798" y="300" width="90" height="60" rx="6"
            data-province="islas-baleares"
            data-province-ja="バレアレス諸島"
            data-url="https://maps.app.goo.gl/td77CJd3kZ4tCron7"
            data-external="true"
            fill={C.islas} fill-opacity="0.75" stroke="white" stroke-width="1"
            class="province-path" />
      <text x="843" y="323" text-anchor="middle" fill="white" font-size="9" font-weight="600" pointer-events="none">バレア</text>
      <text x="843" y="337" text-anchor="middle" fill="white" font-size="8" pointer-events="none">レス諸島</text>
      <line x1="780" y1="340" x2="798" y2="330" stroke="#999" stroke-width="1" stroke-dasharray="3" />
    </g>

    <!-- Canarias inset (bottom-left box) -->
    <g transform="translate(50, 608)">
      <rect x="-5" y="-14" width="220" height="86" rx="5" fill="none" stroke="#aaa" stroke-width="1" stroke-dasharray="4" />
      <text x="105" y="-2" text-anchor="middle" fill="#888" font-size="8" pointer-events="none">カナリア諸島（インセット）</text>
      <!-- Las Palmas -->
      <rect x="0" y="6" width="100" height="58"
            data-province="las-palmas"
            data-province-ja="ラス・パルマス"
            data-url="https://maps.app.goo.gl/KeBk8mQZ6aF5ypep7"
            data-external="true"
            fill={C.islas} fill-opacity="0.75" stroke="white" stroke-width="1"
            class="province-path" rx="4" />
      <text x="50" y="30" text-anchor="middle" fill="white" font-size="9" font-weight="700" pointer-events="none">ラス・パルマス</text>
      <text x="50" y="46" text-anchor="middle" fill="white" font-size="8" pointer-events="none">Las Palmas</text>
      <!-- Santa Cruz de Tenerife -->
      <rect x="108" y="6" width="100" height="58"
            data-province="santa-cruz"
            data-province-ja="テネリフェ"
            data-url="https://maps.app.goo.gl/QcfY6B8o2PLquiqP7"
            data-external="true"
            fill={C.islas} fill-opacity="0.75" stroke="white" stroke-width="1"
            class="province-path" rx="4" />
      <text x="158" y="30" text-anchor="middle" fill="white" font-size="9" font-weight="700" pointer-events="none">テネリフェ</text>
      <text x="158" y="46" text-anchor="middle" fill="white" font-size="8" pointer-events="none">Tenerife</text>
    </g>

    <!-- Guide marker legend inside SVG -->
    <g transform="translate(790, 50)">
      <rect x="-2" y="-2" width="108" height="44" rx="4" fill="white" fill-opacity="0.9" />
      <rect x="4" y="4" width="14" height="14" rx="2" fill="#5D4037" fill-opacity="0.8" stroke="white" stroke-width="1.5" />
      <text x="24" y="14" fill="#002147" font-size="9" font-weight="600">ガイドあり</text>
      <rect x="4" y="24" width="14" height="14" rx="2" fill="#5D4037" fill-opacity="0.8" stroke="#aaa" stroke-width="1" />
      <text x="24" y="34" fill="#6b7280" font-size="9">マップのみ</text>
    </g>
  </svg>

  <!-- Zone color legend -->
  <div class="map-legend">
    {zones.map((z) => (
      <div class="legend-item">
        <span class="legend-dot" style={`background:${z.color};`}></span>
        <span class="legend-label">{z.label}</span>
      </div>
    ))}
    <div class="legend-item">
      <span class="legend-guide-mark"></span>
      <span class="legend-label">枠あり = 編集部ガイドへ</span>
    </div>
    <div class="legend-item">
      <span class="legend-map-mark"></span>
      <span class="legend-label">枠なし = Googleマップへ</span>
    </div>
  </div>
</div>

<style>
  .spain-map-wrap {
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
  }

  .province-path {
    transition: fill-opacity 180ms ease, stroke 180ms ease, stroke-width 180ms ease;
    cursor: pointer;
  }

  .province-path:hover {
    fill-opacity: 1;
    stroke: #C8102E;
    stroke-width: 2;
  }

  .province-path.has-guide {
    stroke: white;
    stroke-width: 2;
  }

  .province-path.has-guide:hover {
    stroke: #C8102E;
    stroke-width: 2.5;
  }

  .map-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 24px;
    margin-top: 16px;
    padding: 16px;
    background: #F9F9F7;
    border-radius: 10px;
    border: 1px solid var(--color-border);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--color-muted);
  }

  .legend-dot {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .legend-guide-mark {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 2px;
    background: #002147;
    border: 2px solid white;
    box-shadow: 0 0 0 1.5px #002147;
    flex-shrink: 0;
  }

  .legend-map-mark {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 2px;
    background: #002147;
    border: 1px solid #aaa;
    flex-shrink: 0;
  }

  .legend-label {
    white-space: nowrap;
  }
</style>

<script>
(function () {
  /* Tooltip element */
  var tooltip = document.createElement('div');
  tooltip.style.cssText = [
    'position:fixed',
    'background:#002147',
    'color:white',
    'padding:10px 14px',
    'border-radius:8px',
    'font-size:13px',
    'pointer-events:none',
    'z-index:1000',
    'border:1px solid rgba(255,255,255,0.2)',
    'max-width:200px',
    'display:none',
    'line-height:1.5',
  ].join(';');
  document.body.appendChild(tooltip);

  document.querySelectorAll('.province-path').forEach(function (path) {
    path.addEventListener('mouseenter', function () {
      var ja = path.getAttribute('data-province-ja') || '';
      var url = path.getAttribute('data-url') || '';
      var isGuide = url.startsWith('/food/') && !url.includes('maps.app');
      tooltip.innerHTML =
        '<strong style="display:block;margin-bottom:4px;">' + ja + '</strong>' +
        '<span style="color:#C8102E;font-size:11px;font-weight:600;">' +
        (isGuide ? 'ガイドを読む →' : 'マップを見る →') +
        '</span>';
      tooltip.style.display = 'block';
    });

    path.addEventListener('mousemove', function (e) {
      var me = e;
      tooltip.style.left = (me.clientX + 14) + 'px';
      tooltip.style.top  = (me.clientY - 40) + 'px';
    });

    path.addEventListener('mouseleave', function () {
      tooltip.style.display = 'none';
    });

    path.addEventListener('click', function () {
      var url = path.getAttribute('data-url');
      var ext = path.getAttribute('data-external') === 'true';
      if (!url) return;
      if (ext) {
        window.open(url, '_blank', 'noopener noreferrer');
      } else {
        window.location.href = url;
      }
    });
  });
})();
</script>
