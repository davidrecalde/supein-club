---
const year = new Date().getFullYear();

const pillars = [
  { href: '/travel/', label: 'スペイン旅行' },
  { href: '/food/', label: 'スペイン料理' },
  { href: '/language/', label: 'スペイン語' },
  { href: '/living/', label: 'スペインに住む' },
  { href: '/culture/', label: 'スペイン文化' },
  { href: '/about-us/', label: 'スペイン倶楽部について' },
];

const socials = [
  { href: 'https://www.instagram.com/supeinclub/', label: 'Instagram', handle: '@supeinclub' },
  { href: 'https://lin.ee/vx6jpud', label: 'LINE', handle: '@spainclub' },
  { href: 'https://www.facebook.com/supeinclub/', label: 'Facebook', handle: 'supeinclub' },
  { href: 'https://twitter.com/supeinclub', label: 'X (Twitter)', handle: '@supeinclub' },
];
---
<footer class="bg-[#001530] text-white/70 text-sm border-t-[3px] border-primary mt-auto">
  <div class="max-w-7xl mx-auto px-5 py-14 grid grid-cols-1 md:grid-cols-3 gap-10">
    <!-- Col 1: Logo + tagline + description -->
    <div>
      <img src="/logo-footer.png" alt="スペイン倶楽部" width="145" height="50" class="h-8 w-auto mb-1" />
      <p class="text-[11px] italic mb-5" style="color: rgba(255,255,255,0.30);">Club Español en Japón</p>
      <p class="leading-relaxed mb-5 text-white/55">
        スペインの料理・旅行・語学・文化を日本語で発信するポータルサイト。スペイン倶楽部が運営しています。
      </p>
      <a
        href="/about-us/"
        class="text-xs border border-white/20 hover:border-primary hover:text-primary px-3 py-1.5 rounded transition-colors inline-block"
      >
        クラブについて →
      </a>
    </div>

    <!-- Col 2: Pillars -->
    <div>
      <p class="font-semibold text-white mb-4 text-xs uppercase tracking-widest">カテゴリ</p>
      <ul class="space-y-2.5">
        {pillars.map(({ href, label }) => (
          <li>
            <a href={href} class="hover:text-white transition-colors">{label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Col 3: Social -->
    <div>
      <p class="font-semibold text-white mb-4 text-xs uppercase tracking-widest">SNS・連絡先</p>
      <ul class="space-y-2.5">
        {socials.map(({ href, label, handle }) => (
          <li>
            <a href={href} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
              {label} <span class="text-white/30">{handle}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10 text-center py-4 px-5 text-xs text-white/30">
    &copy; {year} supein.club — スペイン倶楽部. All rights reserved.
  </div>
</footer>
