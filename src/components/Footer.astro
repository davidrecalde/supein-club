---
const year = new Date().getFullYear();

const pillars = [
  { href: '/travel/', label: 'スペイン旅行' },
  { href: '/food/', label: 'スペイン料理' },
  { href: '/language/', label: 'スペイン語' },
  { href: '/living/', label: 'スペインに住む' },
  { href: '/culture/', label: 'スペイン文化' },
  { href: '/football/', label: 'スペインサッカー' },
];

const abouts = [
  { href: '/about/mission/', label: 'ミッション' },
  { href: '/about/sponsorship/', label: 'スポンサーシップ' },
  { href: '/contact/', label: 'お問い合わせ' },
  { href: '/sitemap/', label: 'サイトマップ' },
  { href: '/privacy/', label: 'プライバシーポリシー' },
  { href: '/terms/', label: '利用規約' },
];

const socials = [
  {
    href: 'https://www.instagram.com/supeinclub/',
    label: 'Instagram',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    href: 'https://lin.ee/vx6jpud',
    label: 'LINE',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>`,
  },
  {
    href: 'https://www.facebook.com/supeinclub/',
    label: 'Facebook',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
  {
    href: 'https://twitter.com/supeinclub',
    label: 'X (Twitter)',
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.622 5.905-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<footer class="bg-[#001530] text-white/70 text-sm border-t-[3px] border-primary mt-auto">
  <div class="footer-grid max-w-7xl mx-auto px-5 py-14 grid grid-cols-1 gap-10">
    <!-- Col 1: Logo + descripción + redes sociales (solo iconos) -->
    <div>
      <img src="/logo-footer.png" alt="スペイン倶楽部" width="145" height="50" class="h-8 w-auto mb-1" />
      <p class="text-[11px] italic mb-5" style="color: rgba(255,255,255,0.30);">Club Español en Japón</p>
      <p class="leading-relaxed mb-6 text-white/55">
        スペインの料理・旅行・語学・文化を日本語で発信するポータルサイト。スペイン倶楽部が運営しています。
      </p>
      <div class="flex gap-2.5">
        {socials.map(({ href, label, svg }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={label}
            class="social-icon flex items-center justify-center rounded-full text-white/60 transition-colors"
            style="width:36px; height:36px; border:1px solid rgba(255,255,255,0.2); flex-shrink:0;"
          >
            <Fragment set:html={svg} />
          </a>
        ))}
      </div>
    </div>

    <!-- Col 2: About -->
    <div>
      <p class="font-semibold text-white mb-4 text-xs uppercase tracking-widest">スペインクラブとは</p>
      <ul class="space-y-2.5">
        {abouts.map(({ href, label }) => (
          <li>
            <a href={href} class="hover:text-white transition-colors">{label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Col 3: Categorías -->
    <div>
      <p class="font-semibold text-white mb-4 text-xs uppercase tracking-widest">カテゴリ</p>
      <ul class="space-y-2.5">
        {pillars.map(({ href, label }) => (
          <li>
            <a href={href} class="hover:text-white transition-colors">{label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Barra inferior -->
  <div class="border-t border-white/10 py-4 px-5 flex flex-wrap items-center justify-between gap-3">
    <p style="color: rgba(255,255,255,0.40); font-size:13px;">
      &copy; {year} supein.club — スペイン倶楽部. All rights reserved.
    </p>
    <a
      href="https://noda.tokyo/"
      rel="nofollow noopener noreferrer"
      target="_blank"
      style="display:inline-flex; align-items:center; gap:6px; opacity:0.5; transition:opacity 200ms; color:white; font-size:12px; color:rgba(255,255,255,0.4);"
      onmouseover="this.style.opacity='0.9'"
      onmouseout="this.style.opacity='0.5'"
    >
      by
      <img
        src="/NODA_texto.png"
        alt="NODA"
        height="16"
        style="filter: brightness(0) invert(1); vertical-align: middle; height:16px; width:auto;"
      />
    </a>
  </div>
</footer>

<style>
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr;
    }
  }
  .social-icon:hover {
    border-color: var(--color-primary, #e63946) !important;
    color: var(--color-primary, #e63946) !important;
  }
</style>
