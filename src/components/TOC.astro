---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  mobileOnly?: boolean;
}

const { headings, mobileOnly = false } = Astro.props;
const h2s = headings.filter((h) => h.depth === 2);
---

{h2s.length > 0 && (
  <!-- MOBILE ONLY: acordeón nativo sin JS -->
  <!-- Visible solo en <1024px gracias al CSS -->
  <details class="toc-mobile">
    <summary class="toc-summary">
      <span class="toc-summary-label">目次</span>
      <span class="toc-chevron" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16"
             fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 6l4 4 4-4" stroke="currentColor"
                stroke-width="1.5" stroke-linecap="round"
                stroke-linejoin="round"/>
        </svg>
      </span>
    </summary>
    <nav aria-label="目次">
      <ol class="toc-mobile-list">
        {h2s.map((h, i) => (
          <li>
            <a href={'#' + h.slug} class="toc-mobile-link">
              <span class="toc-mobile-num">{i + 1}.</span>
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  </details>
)}

{h2s.length > 0 && !mobileOnly && (
  <nav class="toc" aria-label="目次">
    <p class="toc-title">目次</p>
    <div class="toc-track">
      <div class="toc-line-bg" id="toc-line-bg"></div>
      <div class="toc-line-active" id="toc-line"></div>
      <ul class="toc-list">
        {h2s.map((h, i) => (
          <li class="toc-item" data-index={i}>
            <a href={`#${h.slug}`} class="toc-link" data-slug={h.slug}>
              <span class="toc-dot"></span>
              <span class="toc-text">{h.text}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<style>
  .toc {
    font-size: 13px;
  }

  .toc-title {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #9ca3af;
    margin-bottom: 16px;
  }

  .toc-track {
    position: relative;
    padding-left: 20px;
  }

  .toc-line-bg,
  .toc-line-active {
    position: absolute;
    left: 5px;
    width: 1px;
    border-radius: 0;
  }

  .toc-line-bg {
    background: #e5e7eb;
    /* top y height se calculan por JS */
  }

  .toc-line-active {
    background: #C8102E;
    height: 0px;
    transition: height 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .toc-item {
    position: relative;
  }

  .toc-link {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 5px 0;
    color: #9ca3af;
    text-decoration: none;
    transition: color 200ms ease;
    line-height: 1.5;
  }

  .toc-link:hover {
    color: #374151;
  }

  .toc-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 1.5px solid #d1d5db;
    background: white;
    transition: all 200ms ease;
    margin-top: 4px;
    margin-left: -18px;
    position: relative;
    z-index: 1;
  }

  .toc-text {
    flex: 1;
    font-size: 13px;
  }

  .toc-link.is-active {
    color: #002147;
    font-weight: 600;
  }

  .toc-link.is-active .toc-dot {
    border-color: #C8102E;
    background: #C8102E;
    width: 8px;
    height: 8px;
    margin-top: 3px;
    margin-left: -19px;
  }

  .toc-link.is-visited {
    color: #6b7280;
  }

  .toc-link.is-visited .toc-dot {
    border-color: #C8102E;
    background: white;
  }

  /* ━━━ OCULTAR desktop TOC en mobile ━━━ */
  .toc {
    display: none;
  }
  @media (min-width: 1024px) {
    .toc { display: block; }
    .toc-mobile { display: none; }
  }

  /* ━━━ MOBILE TOC — acordeón <details> ━━━ */
  .toc-mobile {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    margin: 0 0 28px 0;
    overflow: hidden;
    background: white;
  }

  @media (min-width: 1024px) {
    .toc-mobile { display: none; }
  }

  .toc-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 18px;
    cursor: pointer;
    user-select: none;
    list-style: none;
    background: #f9fafb;
    border: none;
  }
  .toc-summary::-webkit-details-marker { display: none; }

  .toc-summary-label {
    font-size: 13px;
    font-weight: 600;
    color: #002147;
    letter-spacing: 0.05em;
  }

  .toc-chevron {
    color: #9ca3af;
    display: flex;
    align-items: center;
    transition: transform 250ms ease;
  }
  details[open] .toc-chevron {
    transform: rotate(180deg);
  }

  details.toc-mobile[open] > summary {
    border-bottom: 1px solid #e5e7eb;
  }

  .toc-mobile-list {
    list-style: none;
    margin: 0;
    padding: 6px 0;
  }

  .toc-mobile-link {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 8px 18px;
    font-size: 14px;
    color: #374151;
    text-decoration: none;
    line-height: 1.6;
    transition: background 150ms, color 150ms;
  }
  .toc-mobile-link:hover {
    background: #f3f4f6;
    color: #002147;
  }

  .toc-mobile-num {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 600;
    color: #C8102E;
    min-width: 16px;
  }
</style>

<script>
(function() {
  function initTOC() {
    const tocLinks = document.querySelectorAll('.toc-link');
    const tocLine = document.getElementById('toc-line');
    const tocLineBg = document.getElementById('toc-line-bg');
    const tocTrack = document.querySelector('.toc-track');

    if (!tocLinks.length || !tocLine) return;

    // First try: H2 headings inside .prose or .article-content
    const articleContent = document.querySelector('.prose') || document.querySelector('.article-content');
    let headingEls = articleContent ? Array.from(articleContent.querySelectorAll('h2')) : [];

    // Fallback: use section IDs from TOC link hrefs (for province/landing pages)
    if (headingEls.length === 0) {
      headingEls = [];
      tocLinks.forEach(function(link) {
        var href = link.getAttribute('href');
        if (href && href.startsWith('#')) {
          var el = document.getElementById(href.slice(1));
          if (el) headingEls.push(el);
        }
      });
    }

    if (!headingEls.length) return;

    // Assign IDs to prose H2s if missing; section IDs already exist
    headingEls.forEach(function(el, i) {
      if (!el.id) el.id = 'heading-' + i;
    });

    // Sync link hrefs with heading IDs
    tocLinks.forEach(function(link, i) {
      if (headingEls[i]) link.setAttribute('href', '#' + headingEls[i].id);
    });

    function getDotCenters() {
      if (!tocTrack) return [];
      var trackTop = tocTrack.getBoundingClientRect().top;
      return Array.from(tocLinks).map(function(link) {
        var dot = link.querySelector('.toc-dot');
        if (!dot) return 0;
        var r = dot.getBoundingClientRect();
        return r.top + r.height / 2 - trackTop;
      });
    }

    function updateLines(activeIndex) {
      requestAnimationFrame(function() {
        var centers = getDotCenters();
        if (centers.length < 2) return;
        var first = centers[0];
        var last = centers[centers.length - 1];
        if (tocLineBg) {
          tocLineBg.style.top = first + 'px';
          tocLineBg.style.height = (last - first) + 'px';
        }
        if (activeIndex >= 0 && centers[activeIndex] !== undefined) {
          tocLine.style.top = first + 'px';
          tocLine.style.height = Math.max(0, centers[activeIndex] - first) + 'px';
        } else {
          tocLine.style.top = first + 'px';
          tocLine.style.height = '0px';
        }
      });
    }

    var activeIndex = -1;

    function setActive(index) {
      if (index === activeIndex) return;
      activeIndex = index;
      tocLinks.forEach(function(link, i) {
        link.classList.toggle('is-active', i === index);
        link.classList.toggle('is-visited', i < index);
      });
      updateLines(index);
    }

    requestAnimationFrame(function() {
      updateLines(-1);
      setTimeout(function() { setActive(0); }, 150);
    });

    window.addEventListener('resize', function() { updateLines(activeIndex); });

    var observer = new IntersectionObserver(function(entries) {
      var visible = entries
        .filter(function(e) { return e.isIntersecting; })
        .map(function(e) { return { index: headingEls.indexOf(e.target), top: e.boundingClientRect.top }; })
        .filter(function(e) { return e.index !== -1; })
        .sort(function(a, b) { return a.top - b.top; });
      if (visible.length > 0) setActive(visible[0].index);
    }, { rootMargin: '-80px 0px -55% 0px', threshold: 0 });

    headingEls.forEach(function(el) { observer.observe(el); });

    tocLinks.forEach(function(link, i) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var target = headingEls[i];
        if (target) {
          var top = target.getBoundingClientRect().top + window.scrollY - 90;
          window.scrollTo({ top: top, behavior: 'smooth' });
          setActive(i);
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTOC);
  } else {
    initTOC();
  }
})();
</script>
