---
import { Clock } from 'lucide-astro';

interface Neighborhood {
  name: string;
  nameJa: string;
  vibe: string;
  specialty: string;
  bestTime: string;
}

interface Props {
  neighborhoods: Neighborhood[];
}

const { neighborhoods } = Astro.props;
---
<section style="background:#f8f8f6; padding:72px 0;">
  <div class="container">
    <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:8px;">NEIGHBORHOODS</p>
    <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,32px); margin-bottom:48px;">エリア別グルメガイド</h2>
    <div class="neighborhoods-grid">
      {neighborhoods.map((n) => (
        <div class="neighborhood-card">
          <h3 class="text-navy font-bold" style="font-size:16px; margin:0 0 4px;">{n.name}</h3>
          <p class="text-primary" style="font-size:12px; font-weight:600; margin:0 0 12px;">{n.nameJa}</p>
          <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:12px;">
            {n.vibe.split('·').map((v) => (
              <span style="background:#e5e7eb; border-radius:4px; padding:2px 8px; font-size:12px; color:var(--color-muted);">{v.trim()}</span>
            ))}
          </div>
          <p class="text-muted" style="font-size:14px; margin:0 0 8px;">名物: {n.specialty}</p>
          <p class="text-muted" style="font-size:13px; margin:0; display:flex; align-items:center; gap:6px;">
            <Clock size={13} />
            {n.bestTime}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .neighborhoods-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .neighborhood-card {
    background: white;
    border-left: 4px solid var(--color-primary);
    border-radius: 0 12px 12px 0;
    padding: 24px;
  }
  @media (max-width: 767px) {
    .neighborhoods-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
