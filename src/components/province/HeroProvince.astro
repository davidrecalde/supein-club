---
import { UtensilsCrossed, Sun, Wallet, MapPin } from 'lucide-astro';
import Breadcrumb from '../Breadcrumb.astro';

interface Props {
  provinceJa: string;
  region: string;
  mainDish: string;
  bestSeason: string;
  priceRange: string;
  mapUrl: string;
  lead: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const { provinceJa, region, mainDish, bestSeason, priceRange, mapUrl, lead, breadcrumbs } = Astro.props;
---
<section class="bg-navy text-white relative" style="padding: 80px 0;">
  <div class="absolute top-0 left-0 right-0 h-[3px] bg-primary"></div>
  <div class="container">
    {breadcrumbs && breadcrumbs.length > 0 && (
      <div style="margin-bottom:20px; opacity:0.5;">
        <Breadcrumb items={breadcrumbs} dark />
      </div>
    )}
    <p class="text-primary font-sans font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:16px;">SPANISH FOOD MAP</p>
    <h1 class="font-serif font-bold text-white leading-tight" style="font-size:clamp(28px,5vw,44px); max-width:760px; margin-bottom:16px;">
      {provinceJa}のおすすめレストラン＆グルメガイド
    </h1>
    <p class="text-white/80" style="font-size:18px; max-width:620px; line-height:1.7; margin-bottom:32px;">{lead}</p>

    <div style="display:flex; flex-wrap:wrap; gap:12px; margin-bottom:40px;">
      {[
        { icon: UtensilsCrossed, label: mainDish },
        { icon: Sun, label: bestSeason },
        { icon: Wallet, label: priceRange },
        { icon: MapPin, label: region },
      ].map(({ icon: Icon, label }) => (
        <span style="display:inline-flex; align-items:center; gap:6px; background:rgba(255,255,255,0.1); border-radius:20px; padding:6px 14px; font-size:13px; color:white;">
          <Icon size={14} />
          {label}
        </span>
      ))}
    </div>

    <div style="display:flex; flex-wrap:wrap; gap:16px;">
      <a
        href={mapUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-primary hover:bg-red-dark text-white font-bold rounded-lg transition-colors"
        style="padding:14px 28px; font-size:15px; text-decoration:none; display:inline-block;"
      >
        Googleマップで見る →
      </a>
      <a
        href="https://linktr.ee/supeinclub"
        target="_blank"
        rel="noopener nofollow noreferrer"
        class="text-white font-bold rounded-lg transition-colors"
        style="padding:14px 28px; font-size:15px; text-decoration:none; display:inline-block; border:2px solid rgba(255,255,255,0.6);"
      >
        全マップを見る
      </a>
    </div>
  </div>
</section>

<style>
  @media (max-width: 767px) {
    section {
      padding: 60px 0 !important;
    }
    h1 {
      font-size: 28px !important;
    }
  }
</style>
