---
import type { CollectionEntry } from 'astro:content';

interface Props {
  author: CollectionEntry<'authors'>;
}

const { author } = Astro.props;
const { name, avatar, jobTitle, bio, knowsAbout, sameAs, twitter, linkedin, instagram } = author.data;
const slug = author.data.slug ?? author.id.replace(/\.(md|mdx)$/, '');

const authorUrl = `https://supein.club/authors/${slug}/`;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  url: authorUrl,
  jobTitle,
  description: bio,
  knowsAbout,
  sameAs: sameAs ?? [],
};

function initials(n: string) {
  return n.replace(/[ぁ-んァ-ン一-龯]/g, '').slice(0, 2).toUpperCase() || n.slice(0, 1);
}
---

<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

<aside class="mt-12 mb-8" style="border: 1px solid #e5e7eb; border-top: 3px solid #C8102E; border-radius: 12px; padding: 24px;">
  <p style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin-bottom: 14px; font-weight: 600;">
    この記事の著者
  </p>
  <div style="display: flex; gap: 16px; align-items: flex-start;">
    <!-- Avatar -->
    <div style="flex-shrink: 0;">
      {avatar ? (
        <img
          src={avatar}
          alt={name}
          width="72"
          height="72"
          style="width: 72px; height: 72px; border-radius: 50%; object-fit: cover;"
        />
      ) : (
        <div style="width: 72px; height: 72px; border-radius: 50%; background: #002147; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 20px; flex-shrink: 0;">
          {initials(name)}
        </div>
      )}
    </div>

    <!-- Content -->
    <div style="flex: 1; min-width: 0;">
      <a
        href={`/authors/${slug}/`}
        style="font-weight: 700; font-size: 16px; color: #002147; text-decoration: none; display: block; margin-bottom: 2px;"
        onmouseover="this.style.color='#C8102E'"
        onmouseout="this.style.color='#002147'"
      >
        {name}
      </a>
      <p style="font-size: 13px; color: #C8102E; margin: 0 0 6px;">{jobTitle}</p>
      <p style="font-size: 14px; color: #4b5563; line-height: 1.7; margin: 0;">{bio}</p>

      {knowsAbout.length > 0 && (
        <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px;">
          {knowsAbout.map((topic) => (
            <span style="background: #f3f4f6; color: #374151; font-size: 11px; padding: 2px 8px; border-radius: 4px;">
              {topic}
            </span>
          ))}
        </div>
      )}

      {(twitter || linkedin || instagram) && (
        <div style="display: flex; gap: 10px; margin-top: 12px; align-items: center;">
          {twitter && (
            <a
              href={`https://twitter.com/${twitter}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Twitter"
              style="color: #9ca3af; text-decoration: none; line-height: 1;"
              onmouseover="this.style.color='#C8102E'"
              onmouseout="this.style.color='#9ca3af'"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.26 5.632L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
              </svg>
            </a>
          )}
          {linkedin && (
            <a
              href={`https://linkedin.com/in/${linkedin}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              style="color: #9ca3af; text-decoration: none; line-height: 1;"
              onmouseover="this.style.color='#C8102E'"
              onmouseout="this.style.color='#9ca3af'"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          )}
          {instagram && (
            <a
              href={`https://instagram.com/${instagram}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              style="color: #9ca3af; text-decoration: none; line-height: 1;"
              onmouseover="this.style.color='#C8102E'"
              onmouseout="this.style.color='#9ca3af'"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</aside>
