---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import SEO from '../components/SEO.astro';
import FAQSection from '../components/FAQSection.astro';
import TOC from '../components/TOC.astro';
import LineBanner from '../components/LineBanner.astro';
import HeroProvince from '../components/province/HeroProvince.astro';
import ProvinceQuickGuide from '../components/province/ProvinceQuickGuide.astro';
import ProvinceMapEmbed from '../components/province/ProvinceMapEmbed.astro';
import ProvinceSpecialties from '../components/province/ProvinceSpecialties.astro';
import ProvinceNeighborhoods from '../components/province/ProvinceNeighborhoods.astro';
import ProvinceRelated from '../components/province/ProvinceRelated.astro';
import ProvinceCTA from '../components/province/ProvinceCTA.astro';

interface Props {
  entry: CollectionEntry<'spain-map'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const canonical = `https://supein.club/food/${entry.data.province}-restaurants/`;

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'スペイン料理', url: '/food/' },
  { name: 'スペイン美食マップ', url: '/food/spain-map/' },
  { name: entry.data.provinceJa, url: '' },
];

const tocHeadings = [
  { depth: 2, slug: 'quick-guide', text: '現地で役立つ基本情報' },
  { depth: 2, slug: 'map', text: 'レストランマップ' },
  { depth: 2, slug: 'specialties', text: '郷土料理' },
  { depth: 2, slug: 'neighborhoods', text: 'エリア別ガイド' },
  { depth: 2, slug: 'content', text: '詳細情報' },
  { depth: 2, slug: 'faq', text: 'よくある質問' },
];

const localBusinessSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'Restaurant'],
  name: `${entry.data.provinceJa}のスペイン料理レストラン`,
  description: entry.data.description,
  areaServed: entry.data.province,
  servesCuisine: 'Spanish',
  url: canonical,
});
---
<BaseLayout title={entry.data.title}>
  <SEO
    slot="seo"
    title={`${entry.data.title} | supein.club`}
    description={entry.data.description}
    canonical={canonical}
    breadcrumbs={breadcrumbs}
  />
  <script type="application/ld+json" slot="head" set:html={localBusinessSchema} />

  <HeroProvince
    provinceJa={entry.data.provinceJa}
    region={entry.data.region}
    mainDish={entry.data.mainDish}
    bestSeason={entry.data.bestSeason}
    priceRange={entry.data.priceRange}
    mapUrl={entry.data.mapUrl}
    lead={entry.data.lead}
    breadcrumbs={breadcrumbs}
  />

  <!-- Full-width sections with section IDs for TOC scroll-spy -->
  <section id="quick-guide">
    <ProvinceQuickGuide />
  </section>

  <section id="map">
    <ProvinceMapEmbed mapUrl={entry.data.mapUrl} provinceJa={entry.data.provinceJa} />
  </section>

  {entry.data.specialties && entry.data.specialties.length > 0 && (
    <section id="specialties">
      <ProvinceSpecialties specialties={entry.data.specialties} />
    </section>
  )}

  {entry.data.neighborhoods && entry.data.neighborhoods.length > 0 && (
    <section id="neighborhoods">
      <ProvinceNeighborhoods neighborhoods={entry.data.neighborhoods} />
    </section>
  )}

  <!-- MDX content + TOC sidebar via unified content-grid -->
  <div style="background:var(--color-canvas); padding:48px 0 64px;">
    <div class="page-container">
      <div class="content-grid" id="content">
        <main class="content-main">
          <div class="border-l-4 border-primary rounded-r-lg" style="background:white; padding:20px 24px; margin-bottom:32px;">
            <p class="text-ink leading-relaxed font-medium" style="margin:0;">{entry.data.lead}</p>
          </div>
          <div class="prose">
            <Content />
          </div>
        </main>

        <aside class="content-sidebar">
          <TOC headings={tocHeadings} />
        </aside>
      </div>

      {entry.data.faq.length > 0 && (
        <div id="faq" style="margin-top:48px; max-width:860px;">
          <FAQSection faq={entry.data.faq} />
        </div>
      )}
    </div>
  </div>

  <ProvinceRelated
    relatedTravel={entry.data.relatedTravel}
    relatedFood={entry.data.relatedFood}
    provinceJa={entry.data.provinceJa}
  />

  <ProvinceCTA provinceJa={entry.data.provinceJa} />

  <LineBanner />
</BaseLayout>
