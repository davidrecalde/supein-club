---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import { getCollection } from 'astro:content';
import Breadcrumb from '../../components/Breadcrumb.astro';

const releases = await getCollection('press-releases', e => !e.data.draft);
releases.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const canonical = 'https://supein.club/newsroom/';

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'プレスルーム', url: '' },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': canonical,
      url: canonical,
      name: 'プレスルーム | スペイン倶楽部',
      description: 'スペイン倶楽部のプレスリリース、報道関係者向け情報、プレスキット。',
      inLanguage: 'ja',
      isPartOf: { '@id': 'https://supein.club/#website' },
      breadcrumb: {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://supein.club/' },
          { '@type': 'ListItem', position: 2, name: 'プレスルーム', item: canonical },
        ],
      },
    },
    {
      '@type': 'ItemList',
      name: 'プレスリリース一覧',
      url: canonical,
      numberOfItems: releases.length,
      itemListElement: releases.map((r, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `https://supein.club/newsroom/${r.slug}/`,
        name: r.data.title,
      })),
    },
    {
      '@type': 'Organization',
      '@id': 'https://supein.club/#organization',
      name: 'Club Español en Japón スペイン倶楽部',
      url: 'https://supein.club',
      logo: 'https://supein.club/logo-og.png',
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'press',
        email: 'clubsupein@gmail.com',
        availableLanguage: ['Japanese', 'Spanish', 'English'],
        url: 'https://supein.club/contact/',
      },
    },
  ],
};
---

<BaseLayout title="プレスルーム | スペイン倶楽部">
  <SEO
    slot="seo"
    title="プレスルーム | スペイン倶楽部"
    description="スペイン倶楽部のプレスリリース、報道関係者向け情報、プレスキット。取材・掲載のご依頼はこちらから。"
    canonical={canonical}
    breadcrumbs={breadcrumbs}
  />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section style="background:#002147; padding:72px 0 56px;">
    <div class="page-container">
      <Breadcrumb items={breadcrumbs} dark={true} />
      <p style="font-size:11px; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; color:#C8102E; margin:24px 0 12px;">
        NEWSROOM
      </p>
      <h1 style="font-family:'Noto Serif JP',serif; font-size:clamp(32px,5vw,48px); font-weight:700; color:white; margin:0 0 16px; line-height:1.2;">
        プレスルーム
      </h1>
      <p style="font-size:17px; color:rgba(255,255,255,0.75); max-width:560px; line-height:1.8; margin:0;">
        スペイン倶楽部に関するプレスリリース、報道関係者向け情報、プレスキットを掲載しています。
      </p>
    </div>
  </section>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- SECCIÓN 1 — NOTAS DE PRENSA          -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section style="background:white; padding:80px 0;">
    <div class="page-container">

      <p style="font-size:11px; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; color:#C8102E; margin:0 0 8px;">
        PRESS RELEASES
      </p>
      <h2 style="font-family:'Noto Serif JP',serif; font-size:clamp(24px,3vw,32px); font-weight:700; color:#002147; margin:0 0 8px;">
        ノートデプレンサ
      </h2>
      <p style="font-size:15px; color:#6b7280; margin:0 0 48px;">
        プレスリリース・活動報告
      </p>

      {releases.length === 0 ? (
        <p style="color:#9ca3af; font-size:15px; text-align:center; padding:40px 0;">
          プレスリリースを準備中です。
        </p>
      ) : (
        <div>
          {releases.map(release => (
            <article style="border-bottom:1px solid #e5e7eb; padding:28px 0;">
              <div class="press-item">

                <!-- Fecha -->
                <time class="press-date" datetime={release.data.date.toISOString()}
                  style="font-size:13px; color:#9ca3af; font-variant-numeric:tabular-nums;">
                  {release.data.date.toLocaleDateString('ja-JP', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>

                <!-- Contenido principal -->
                <div class="press-content">
                  <span style="display:inline-block; background:rgba(200,16,46,0.08); color:#C8102E; font-size:11px; font-weight:600; padding:2px 10px; border-radius:4px; margin-bottom:10px;">
                    {release.data.category}
                  </span>
                  <h3 style="font-size:clamp(15px,2vw,17px); font-weight:700; color:#002147; margin:0 0 8px; line-height:1.5;">
                    <a href={`/newsroom/${release.slug}/`} style="text-decoration:none; color:inherit; transition:color 150ms;">
                      {release.data.title}
                    </a>
                  </h3>
                  <p style="font-size:14px; color:#6b7280; margin:0; line-height:1.7;">
                    {release.data.summary}
                  </p>
                </div>

                <!-- CTA -->
                <div class="press-cta">
                  <a href={`/newsroom/${release.slug}/`}
                    style="font-size:13px; color:#C8102E; font-weight:600; text-decoration:none; white-space:nowrap; display:inline-flex; align-items:center; gap:4px;">
                    詳細を読む
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>

              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- SECCIÓN 2 — CONTACTO PRENSA          -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section style="background:#FAFAF8; padding:80px 0;">
    <div class="page-container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:start;" class="press-contact-grid">

        <!-- Info izquierda -->
        <div>
          <p style="font-size:11px; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; color:#C8102E; margin:0 0 8px;">
            PRESS CONTACT
          </p>
          <h2 style="font-family:'Noto Serif JP',serif; font-size:clamp(22px,3vw,28px); font-weight:700; color:#002147; margin:0 0 20px;">
            報道関係者のお問い合わせ
          </h2>
          <p style="font-size:16px; color:#374151; line-height:1.8; margin:0 0 24px;">
            取材依頼、メディア掲載、コメント提供、写真素材のご要望など、報道関係のお問い合わせはお問い合わせフォームよりご連絡ください。通常1〜2営業日以内にご返信いたします。
          </p>
          <div style="display:flex; flex-direction:column; gap:12px;">
            <div style="display:flex; align-items:center; gap:10px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C8102E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              <span style="font-size:14px; color:#374151;">担当: David Recalde（創設者）</span>
            </div>
            <div style="display:flex; align-items:center; gap:10px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C8102E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
              <span style="font-size:14px; color:#374151;">対応言語: 日本語・スペイン語・英語</span>
            </div>
            <div style="display:flex; align-items:center; gap:10px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C8102E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span style="font-size:14px; color:#374151;">返信時間: 1〜2営業日以内</span>
            </div>
          </div>
        </div>

        <!-- Card derecha -->
        <div style="background:#002147; border-radius:16px; padding:36px; text-align:center;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#C8102E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 16px; display:block;">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          <h3 style="font-size:18px; font-weight:700; color:white; margin:0 0 10px;">
            プレスのご連絡はこちら
          </h3>
          <p style="font-size:14px; color:rgba(255,255,255,0.65); margin:0 0 24px; line-height:1.6;">
            取材・掲載のご依頼、素材のご要望はフォームよりお気軽にどうぞ。
          </p>
          <a href="/contact/"
            style="display:inline-flex; align-items:center; gap:8px; background:#C8102E; color:white; font-weight:600; font-size:15px; padding:14px 28px; border-radius:8px; text-decoration:none; transition:background 200ms;">
            お問い合わせフォーム →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- SECCIÓN 3 — PRESS KIT               -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section style="background:white; padding:80px 0;">
    <div class="page-container">

      <p style="font-size:11px; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; color:#C8102E; margin:0 0 8px;">
        PRESS KIT
      </p>
      <h2 style="font-family:'Noto Serif JP',serif; font-size:clamp(22px,3vw,28px); font-weight:700; color:#002147; margin:0 0 16px;">
        プレスキット
      </h2>
      <p style="font-size:16px; color:#374151; line-height:1.8; max-width:680px; margin:0 0 40px;">
        スペイン倶楽部のブランドガイドライン、ロゴデータ、チームプロフィール、ブランドストーリーをまとめたプレスキットです。取材・掲載の際にご活用ください。
      </p>

      <!-- 2 cards de descarga -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; max-width:640px; margin-bottom:32px;" class="press-kit-grid">

        <!-- Japonés -->
        <div style="background:#002147; border-radius:12px; padding:28px 24px; text-align:center;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(200,16,46,0.8)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 14px; display:block;">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <p style="font-size:15px; font-weight:700; color:white; margin:0 0 4px;">プレスキット（日本語版）</p>
          <p style="font-size:12px; color:rgba(255,255,255,0.5); margin:0 0 18px;">Brand Dossier in Japanese</p>
          <span style="display:inline-block; background:rgba(255,255,255,0.1); color:rgba(255,255,255,0.4); font-size:12px; font-weight:600; padding:8px 20px; border-radius:6px; cursor:not-allowed;">
            準備中
          </span>
        </div>

        <!-- Inglés -->
        <div style="background:#002147; border-radius:12px; padding:28px 24px; text-align:center;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(200,16,46,0.8)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 14px; display:block;">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <p style="font-size:15px; font-weight:700; color:white; margin:0 0 4px;">Press Kit (English)</p>
          <p style="font-size:12px; color:rgba(255,255,255,0.5); margin:0 0 18px;">Brand Dossier in English</p>
          <span style="display:inline-block; background:rgba(255,255,255,0.1); color:rgba(255,255,255,0.4); font-size:12px; font-weight:600; padding:8px 20px; border-radius:6px; cursor:not-allowed;">
            Coming soon
          </span>
        </div>

      </div>

      <p style="font-size:14px; color:#6b7280; line-height:1.7; max-width:560px;">
        プレスキットのご要望は
        <a href="/contact/" style="color:#C8102E; font-weight:600; text-decoration:none;">お問い合わせフォーム</a>
        よりご連絡ください。2〜3営業日以内にお送りします。
      </p>

    </div>
  </section>

</BaseLayout>

<style>
  .press-item {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    gap: 24px;
    align-items: start;
  }
  @media (max-width: 767px) {
    .press-item {
      grid-template-columns: 1fr;
      gap: 10px;
    }
    .press-cta {
      margin-top: 4px;
    }
    .press-contact-grid {
      grid-template-columns: 1fr !important;
    }
    .press-kit-grid {
      grid-template-columns: 1fr !important;
      max-width: 100% !important;
    }
  }
  @media (max-width: 1023px) {
    .press-contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
