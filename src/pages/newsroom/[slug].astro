---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import { getCollection } from 'astro:content';
import Breadcrumb from '../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const releases = await getCollection('press-releases', e => !e.data.draft);
  return releases.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, subtitle, date, category, summary, location, quote, quoteAuthor, quoteRole, boilerplate } = entry.data;

const canonical = `https://supein.club/newsroom/${entry.slug}/`;

const dateFormatted = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'プレスルーム', url: '/newsroom/' },
  { name: title, url: '' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: title,
  description: summary,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  url: canonical,
  inLanguage: 'ja',
  author: {
    '@type': 'Organization',
    name: 'Club Español en Japón スペイン倶楽部',
    url: 'https://supein.club',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Club Español en Japón スペイン倶楽部',
    logo: {
      '@type': 'ImageObject',
      url: 'https://supein.club/logo-og.png',
      width: 600,
      height: 60,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
  articleSection: category,
  about: {
    '@type': 'Organization',
    name: 'Club Español en Japón スペイン倶楽部',
    url: 'https://supein.club',
  },
};
---

<BaseLayout title={`${title} | プレスルーム | スペイン倶楽部`}>
  <SEO
    slot="seo"
    title={`${title} | プレスルーム | スペイン倶楽部`}
    description={summary}
    canonical={canonical}
    breadcrumbs={breadcrumbs}
  />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- ━━━━ HERO -->
  <header style="background:#002147; padding:64px 0 48px;">
    <div class="page-container">
      <Breadcrumb items={breadcrumbs} dark={true} />

      <div style="margin-top:28px; margin-bottom:24px;">
        <span style="display:inline-flex; align-items:center; gap:8px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:6px; padding:6px 14px;">
          <img src="/logo-header.png" alt="スペイン倶楽部" height="20" style="height:20px; width:auto;" />
          <span style="font-size:10px; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; color:rgba(255,255,255,0.5);">
            PRESS RELEASE
          </span>
        </span>
      </div>

      <span style="display:inline-block; background:rgba(200,16,46,0.25); color:#ff6b8a; font-size:11px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; padding:3px 12px; border-radius:4px; margin-bottom:16px;">
        {category}
      </span>

      <h1 style="font-family:'Noto Serif JP',serif; font-size:clamp(24px,4vw,40px); font-weight:700; color:white; margin:0 0 16px; line-height:1.3; max-width:800px;">
        {title}
      </h1>

      {subtitle && (
        <p style="font-size:clamp(16px,2vw,19px); color:rgba(255,255,255,0.7); line-height:1.7; max-width:720px; margin:0 0 28px; font-weight:400; border-left:3px solid #C8102E; padding-left:16px;">
          {subtitle}
        </p>
      )}

      <time datetime={date.toISOString()} style="font-size:13px; font-weight:600; color:rgba(255,255,255,0.55); letter-spacing:0.05em;">
        {location} — {dateFormatted}
      </time>
    </div>
  </header>

  <!-- ━━━━ CUERPO PRINCIPAL -->
  <main style="background:white; padding:64px 0 0;">
    <div class="page-container">
      <div style="display:grid; grid-template-columns:1fr 300px; gap:64px; align-items:start;" class="press-body-grid">

        <!-- COLUMNA PRINCIPAL -->
        <article>

          <div class="press-prose">
            <Content />
          </div>

          {quote && (
            <blockquote style="margin:40px 0; padding:28px 32px; background:#FAFAF8; border-left:4px solid #C8102E; border-radius:0 12px 12px 0;">
              <p style="font-family:'Noto Serif JP',serif; font-size:clamp(17px,2vw,20px); font-style:italic; color:#002147; line-height:1.8; margin:0 0 16px;">
                「{quote}」
              </p>
              <footer style="font-size:13px; color:#6b7280;">
                <strong style="color:#374151; font-style:normal;">{quoteAuthor}</strong>
                {quoteRole && <span>、{quoteRole}</span>}
              </footer>
            </blockquote>
          )}

          <hr style="border:none; border-top:1px solid #e5e7eb; margin:48px 0;" />

          {boilerplate && (
            <section style="margin-bottom:40px;">
              <h2 style="font-size:13px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#9ca3af; margin:0 0 12px;">
                スペイン倶楽部について
              </h2>
              <p style="font-size:14px; color:#6b7280; line-height:1.8; margin:0;">
                {boilerplate}
              </p>
            </section>
          )}

          <!-- CONTACTO DE PRENSA -->
          <section style="background:#FAFAF8; border:1px solid #e5e7eb; border-radius:12px; padding:28px; margin-bottom:48px;">
            <h2 style="font-size:13px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#9ca3af; margin:0 0 16px;">
              報道関係者のお問い合わせ
            </h2>
            <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap;">
              <img src="/David-Recalde.webp" alt="David Recalde" width="48" height="48"
                style="width:48px; height:48px; border-radius:50%; object-fit:cover; flex-shrink:0;" />
              <div>
                <p style="font-weight:700; color:#002147; font-size:15px; margin:0 0 2px;">David Recalde</p>
                <p style="font-size:13px; color:#6b7280; margin:0;">Club Español en Japón 創設者</p>
              </div>
              <a href="/contact/" style="margin-left:auto; display:inline-flex; align-items:center; gap:6px; background:#002147; color:white; font-size:13px; font-weight:600; padding:10px 20px; border-radius:8px; text-decoration:none;">
                お問い合わせ →
              </a>
            </div>
          </section>

          <div style="margin-bottom:64px;">
            <a href="/newsroom/" style="display:inline-flex; align-items:center; gap:6px; font-size:14px; color:#6b7280; text-decoration:none; font-weight:500;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
              </svg>
              プレスルームに戻る
            </a>
          </div>

        </article>

        <!-- SIDEBAR -->
        <aside style="position:sticky; top:80px; height:fit-content;" class="press-sidebar">

          <div style="background:#FAFAF8; border:1px solid #e5e7eb; border-radius:12px; padding:24px; margin-bottom:24px;">
            <h3 style="font-size:11px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#9ca3af; margin:0 0 16px;">
              このリリースについて
            </h3>
            <dl style="margin:0;">
              <dt style="font-size:11px; color:#9ca3af; font-weight:600; margin-bottom:4px;">発行日</dt>
              <dd style="font-size:14px; color:#374151; margin:0 0 16px; font-weight:500;">{dateFormatted}</dd>
              <dt style="font-size:11px; color:#9ca3af; font-weight:600; margin-bottom:4px;">カテゴリ</dt>
              <dd style="margin:0 0 16px;">
                <span style="display:inline-block; background:rgba(200,16,46,0.08); color:#C8102E; font-size:12px; font-weight:600; padding:3px 10px; border-radius:4px;">
                  {category}
                </span>
              </dd>
              <dt style="font-size:11px; color:#9ca3af; font-weight:600; margin-bottom:4px;">発信元</dt>
              <dd style="font-size:14px; color:#374151; margin:0; font-weight:500;">東京、日本</dd>
            </dl>
          </div>

          <div style="border:1px solid #e5e7eb; border-radius:12px; padding:24px;">
            <h3 style="font-size:11px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#9ca3af; margin:0 0 16px;">
              関連リンク
            </h3>
            <nav style="display:flex; flex-direction:column; gap:8px;">
              <a href="/newsroom/" style="font-size:13px; color:#374151; text-decoration:none; font-weight:500;">→ プレスルーム一覧</a>
              <a href="/newsroom/press-kit/" style="font-size:13px; color:#374151; text-decoration:none; font-weight:500;">→ プレスキット</a>
              <a href="/about-us/" style="font-size:13px; color:#374151; text-decoration:none; font-weight:500;">→ スペイン倶楽部とは</a>
              <a href="/contact/" style="font-size:13px; color:#C8102E; text-decoration:none; font-weight:600;">→ 取材・掲載のお問い合わせ</a>
            </nav>
          </div>

        </aside>

      </div>
    </div>
  </main>

</BaseLayout>

<style>
  .press-prose > p:first-child {
    font-size: clamp(17px, 2vw, 19px);
    color: #1f2937;
    line-height: 1.8;
    font-weight: 500;
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid #e5e7eb;
  }
  .press-prose {
    font-size: 16px;
    line-height: 1.9;
    color: #374151;
  }
  .press-prose h2 {
    font-family: 'Noto Serif JP', serif;
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 700;
    color: #002147;
    margin: 40px 0 16px;
    padding-top: 8px;
    border-top: 2px solid #e5e7eb;
  }
  .press-prose h3 {
    font-size: clamp(16px, 2vw, 18px);
    font-weight: 700;
    color: #002147;
    margin: 28px 0 12px;
  }
  .press-prose p {
    margin: 0 0 20px;
  }
  .press-prose ul,
  .press-prose ol {
    padding-left: 24px;
    margin: 0 0 20px;
  }
  .press-prose li {
    margin-bottom: 8px;
    line-height: 1.7;
  }
  .press-prose a {
    color: #C8102E;
    font-weight: 600;
  }
  .press-prose strong {
    color: #002147;
  }
  @media (max-width: 1023px) {
    .press-body-grid {
      grid-template-columns: 1fr !important;
    }
    .press-sidebar {
      position: static !important;
      order: -1;
    }
  }
</style>
