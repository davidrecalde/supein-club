---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import LineBanner from '../../../components/LineBanner.astro';
---
<BaseLayout>
  <SEO slot="seo" title="スペイン留学サポート | スペイン倶楽部" description="スペイン留学をお考えの方へ。学校選び・ビザ申請・渡航準備まで、スペイン倶楽部が留学をサポートします。" canonical="https://supein.club/services/study-abroad-support/" />
  <section class="bg-navy text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-4">スペイン留学サポート</h1>
      <p class="text-white/80 text-lg">スペイン留学の夢を実現するためのサポートを提供します</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 py-12 space-y-8">
    <div>
      <h2 class="font-serif text-2xl font-bold text-navy mb-3">サポート内容</h2>
      <p class="text-muted leading-relaxed">語学学校・大学の選定から、ビザ申請手続き、現地での生活立ち上げまで、留学に関するすべてのプロセスをサポートします。</p>
    </div>
    <div>
      <h2 class="font-serif text-2xl font-bold text-navy mb-3">お問い合わせ</h2>
      <p class="text-muted leading-relaxed">まずはLINEからお気軽にご相談ください。無料相談を実施中です。</p>
    </div>
  </section>
  <LineBanner />
</BaseLayout>
