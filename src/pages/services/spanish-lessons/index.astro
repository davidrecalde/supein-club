---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import LineBanner from '../../../components/LineBanner.astro';
---
<BaseLayout>
  <SEO slot="seo" title="スペイン語レッスン | スペイン倶楽部" description="スペイン倶楽部が提供するスペイン語レッスン。初心者から上級者まで、グループ・マンツーマンレッスンをご用意しています。" canonical="https://supein.club/services/spanish-lessons/" />
  <section class="bg-navy text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-4">スペイン語レッスン</h1>
      <p class="text-white/80 text-lg">Club Español en Japón — スペイン語を楽しく学ぼう</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 py-12 space-y-8">
    <div>
      <h2 class="font-serif text-2xl font-bold text-navy mb-3">レッスン内容</h2>
      <p class="text-muted leading-relaxed">初心者から上級者まで対応したスペイン語レッスン。グループレッスン・マンツーマンレッスンをご用意しています。ネイティブ講師と日本人講師が在籍し、目標に合わせたカリキュラムを提供します。</p>
    </div>
    <div>
      <h2 class="font-serif text-2xl font-bold text-navy mb-3">お問い合わせ</h2>
      <p class="text-muted leading-relaxed">レッスンのご予約・お問い合わせはLINEからお気軽にどうぞ。</p>
    </div>
  </section>
  <LineBanner />
</BaseLayout>
