---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: '利用規約', url: '/terms/' },
];
---
<BaseLayout>
  <SEO slot="seo" title="利用規約 | スペイン倶楽部" description="supein.club・スペイン倶楽部の利用規約。" canonical="https://supein.club/terms/" breadcrumbs={breadcrumbs} />
  <section class="bg-navy text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-4">利用規約</h1>
      <p class="text-white/80 text-lg">当サイトのご利用について</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-white rounded-2xl shadow-sm border border-ink/5 p-8">
      <p class="text-muted leading-relaxed">このページは現在準備中です。</p>
    </div>
  </section>
</BaseLayout>
