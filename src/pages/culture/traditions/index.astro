---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import LineBanner from '../../../components/LineBanner.astro';

const articles = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'culture' && data.cluster === 'traditions');
const sorted = articles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'スペイン文化', url: '/culture/' },
  { name: 'スペインの伝統・祭り', url: '/culture/traditions/' },
];
---
<BaseLayout>
  <SEO slot="seo" title="スペインの伝統・祭り | supein.club" description="トマト祭り・牛追い・セマナサンタなどスペインの伝統行事と祭りを解説。開催時期・見どころも紹介。" canonical="https://supein.club/culture/traditions/" breadcrumbs={breadcrumbs} />
  <section class="bg-navy text-white py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <Breadcrumb items={breadcrumbs} dark />
      <h1 class="font-serif text-3xl md:text-4xl font-bold leading-tight mt-4">スペインの伝統・祭り ガイド</h1>
      <p class="text-white/80 text-lg mt-3 max-w-2xl">世界的に有名なパンプローナの牛追い・ブニョールのトマト祭りなどスペインの祭りを徹底解説。</p>
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-4 py-12">
    {sorted.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {sorted.map((a) => {
          const parts = a.id.replace(/\.(md|mdx)$/, '').split('/');
          const slug = parts[2] ?? a.data.cluster;
          return <ArticleCard title={a.data.title} description={a.data.description} href={`/culture/traditions/${slug}/`} pillar="culture" image={a.data.image} imageAlt={a.data.imageAlt} pubDate={a.data.pubDate} />;
        })}
      </div>
    ) : (
      <p class="text-muted text-center py-12">記事を準備中です。近日公開予定。</p>
    )}
  </section>
  <LineBanner />
</BaseLayout>
