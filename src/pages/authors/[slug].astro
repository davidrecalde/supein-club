---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const authors = await getCollection('authors', ({ data }) => data.active !== false);
  return authors.map((author) => ({
    params: { slug: author.data.slug ?? author.id.replace(/\.(md|mdx)$/, '') },
    props: { author },
  }));
}

interface Props {
  author: CollectionEntry<'authors'>;
}

const { author } = Astro.props;
const { name, avatar, jobTitle, bio, bioLong, knowsAbout, sameAs, twitter, linkedin, instagram } = author.data;
const slug = author.data.slug ?? author.id.replace(/\.(md|mdx)$/, '');

const authorUrl = `https://supein.club/authors/${slug}/`;

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const articles = allArticles.filter((a) => {
  const ref = a.data.author;
  const refId = typeof ref === 'object' && 'id' in ref ? ref.id : String(ref);
  return refId === author.id || refId === author.id.replace(/\.(md|mdx)$/, '');
}).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: '著者', url: '/authors/' },
  { name: name, url: `/authors/${slug}/` },
];

const profileSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfilePage',
      url: authorUrl,
      name: `${name} — スペイン倶楽部 ライター`,
      mainEntity: {
        '@type': 'Person',
        name,
        url: authorUrl,
        image: avatar ?? null,
        jobTitle,
        description: bio,
        knowsAbout,
        sameAs: sameAs ?? [],
        worksFor: {
          '@type': 'Organization',
          name: 'スペイン倶楽部',
          url: 'https://supein.club',
        },
      },
      hasPart: articles.map((a) => {
        const parts = a.id.replace(/\.(md|mdx)$/, '').split('/');
        const articleSlug = parts[2] ?? a.data.cluster;
        return {
          '@type': 'Article',
          url: `https://supein.club/${a.data.pillar}/${a.data.cluster}/${articleSlug}/`,
          name: a.data.title,
        };
      }),
    },
  ],
};

function initials(n: string) {
  return n.replace(/[ぁ-んァ-ン一-龯]/g, '').slice(0, 2).toUpperCase() || n.slice(0, 1);
}
---

<BaseLayout title={`${name} — スペイン倶楽部 ライター`}>
  <SEO
    slot="seo"
    title={`${name} — スペイン倶楽部 ライター`}
    description={bio}
    canonical={authorUrl}
    breadcrumbs={breadcrumbs}
    pageSchema="profile"
  />

  <script type="application/ld+json" slot="head" set:html={JSON.stringify(profileSchema)} />

  <!-- Header -->
  <div class="bg-navy text-white relative">
    <div class="absolute top-0 left-0 right-0 h-[3px] bg-primary"></div>
    <div class="max-w-4xl mx-auto px-5 py-10 pt-14">
      <Breadcrumb items={breadcrumbs} dark />
      <div class="flex items-center gap-6 mt-8">
        {avatar ? (
          <img
            src={avatar}
            alt={name}
            width="120"
            height="120"
            class="rounded-full object-cover flex-shrink-0"
            style="width: 120px; height: 120px;"
          />
        ) : (
          <div
            class="rounded-full bg-white/10 flex items-center justify-center flex-shrink-0 font-bold text-3xl"
            style="width: 120px; height: 120px;"
          >
            {initials(name)}
          </div>
        )}
        <div>
          <h1 class="font-sans font-bold text-3xl md:text-4xl leading-tight">{name}</h1>
          <p class="text-primary font-semibold mt-2">{jobTitle}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Body -->
  <div class="max-w-4xl mx-auto px-5 py-12">
    <!-- Bio -->
    <p class="text-ink leading-relaxed text-base mb-6 max-w-2xl">
      {bioLong ?? bio}
    </p>

    <!-- knowsAbout chips -->
    {knowsAbout.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6">
        {knowsAbout.map((topic) => (
          <span class="bg-navy text-white text-xs font-medium px-3 py-1 rounded-full">
            {topic}
          </span>
        ))}
      </div>
    )}

    <!-- Social links -->
    {(twitter || linkedin || instagram || (sameAs && sameAs.length > 0)) && (
      <div class="flex gap-4 items-center mb-10">
        {twitter && (
          <a
            href={`https://twitter.com/${twitter}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-muted hover:text-primary transition-colors text-sm"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.26 5.632L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
            Twitter
          </a>
        )}
        {linkedin && (
          <a
            href={`https://linkedin.com/in/${linkedin}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-muted hover:text-primary transition-colors text-sm"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        )}
        {instagram && (
          <a
            href={`https://instagram.com/${instagram}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-muted hover:text-primary transition-colors text-sm"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
            Instagram
          </a>
        )}
      </div>
    )}

    <!-- Articles grid -->
    {articles.length > 0 && (
      <section>
        <h2 class="font-sans font-bold text-2xl text-navy mb-6">{name}の記事一覧</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {articles.map((a) => {
            const parts = a.id.replace(/\.(md|mdx)$/, '').split('/');
            const articleSlug = parts[2] ?? a.data.cluster;
            return (
              <ArticleCard
                title={a.data.title}
                description={a.data.description}
                href={`/${a.data.pillar}/${a.data.cluster}/${articleSlug}/`}
                pillar={a.data.pillar}
                image={a.data.image}
                imageAlt={a.data.imageAlt}
                pubDate={a.data.pubDate}
              />
            );
          })}
        </div>
      </section>
    )}

    {articles.length === 0 && (
      <p class="text-muted text-center py-12">記事を準備中です。近日公開予定。</p>
    )}
  </div>
</BaseLayout>
