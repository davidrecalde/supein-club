---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import LineBanner from '../../../components/LineBanner.astro';

const articles = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'living' && data.cluster === 'spain-visa');
const sorted = articles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'スペインに住む', url: '/living/' },
  { name: 'スペインビザ 種類・申請方法', url: '/living/spain-visa/' },
];
---
<BaseLayout>
  <SEO slot="seo" title="スペインビザ 種類・申請方法 | supein.club" description="スペインビザの種類（観光・学生・就労・デジタルノマド）と申請手続きを日本語でわかりやすく解説。" canonical="https://supein.club/living/spain-visa/" breadcrumbs={breadcrumbs} />
  <section class="bg-navy text-white py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <Breadcrumb items={breadcrumbs} dark />
      <h1 class="font-serif text-3xl md:text-4xl font-bold leading-tight mt-4">スペインビザ 種類と申請手続き</h1>
      <p class="text-white/80 text-lg mt-3 max-w-2xl">スペインに滞在・住むためのビザの種類と申請方法を目的別にわかりやすく説明します。</p>
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-4 py-12">
    {sorted.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {sorted.map((a) => {
          const parts = a.id.replace(/\.(md|mdx)$/, '').split('/');
          const slug = parts[2] ?? a.data.cluster;
          return <ArticleCard title={a.data.title} description={a.data.description} href={`/living/spain-visa/${slug}/`} pillar="living" image={a.data.image} imageAlt={a.data.imageAlt} pubDate={a.data.pubDate} />;
        })}
      </div>
    ) : (
      <p class="text-muted text-center py-12">記事を準備中です。近日公開予定。</p>
    )}
  </section>
  <LineBanner />
</BaseLayout>
