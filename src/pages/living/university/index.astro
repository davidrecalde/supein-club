---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import LineBanner from '../../../components/LineBanner.astro';

const articles = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'living' && data.cluster === 'university');
const sorted = articles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'スペインに住む', url: '/living/' },
  { name: 'スペイン 大学留学', url: '/living/university/' },
];
---
<BaseLayout>
  <SEO slot="seo" title="スペイン 大学留学 | supein.club" description="スペインの大学留学・交換留学の方法を解説。主要大学・出願手続き・奨学金情報を日本語で紹介。" canonical="https://supein.club/living/university/" breadcrumbs={breadcrumbs} />
  <section class="bg-navy text-white py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <Breadcrumb items={breadcrumbs} dark />
      <h1 class="font-serif text-3xl md:text-4xl font-bold leading-tight mt-4">スペイン大学留学 方法・大学一覧</h1>
      <p class="text-white/80 text-lg mt-3 max-w-2xl">マドリード自治大学・バルセロナ大学など名門校への留学方法と必要な準備を詳しく解説します。</p>
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-4 py-12">
    {sorted.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {sorted.map((a) => {
          const parts = a.id.replace(/\.(md|mdx)$/, '').split('/');
          const slug = parts[2] ?? a.data.cluster;
          return <ArticleCard title={a.data.title} description={a.data.description} href={`/living/university/${slug}/`} pillar="living" image={a.data.image} imageAlt={a.data.imageAlt} pubDate={a.data.pubDate} />;
        })}
      </div>
    ) : (
      <p class="text-muted text-center py-12">記事を準備中です。近日公開予定。</p>
    )}
  </section>
  <LineBanner />
</BaseLayout>
