---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'ミッション', url: '/about/mission/' },
];
---
<BaseLayout>
  <SEO slot="seo" title="ミッション | スペイン倶楽部" description="supein.club・スペイン倶楽部のミッションについて。" canonical="https://supein.club/about/mission/" breadcrumbs={breadcrumbs} />
  <section class="bg-navy text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-4">私たちのミッション</h1>
      <p class="text-white/80 text-lg">スペインと日本をつなぐ架け橋になる</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-white rounded-2xl shadow-sm border border-ink/5 p-8">
      <p class="text-muted leading-relaxed">このページは現在準備中です。</p>
    </div>
  </section>
</BaseLayout>
