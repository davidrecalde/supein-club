---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import LineBanner from '../../components/LineBanner.astro';
import { Users, Lightbulb, Link2, Leaf, Type, Circle, Palette } from 'lucide-astro';

const allAuthors = await getCollection('authors', ({ data }) => data.active !== false);
const featuredAuthors = allAuthors.filter((a) => a.data.featured);
function teamSlug(a: typeof allAuthors[number]) {
  return a.data.slug ?? a.id.replace(/\.(md|mdx)$/, '');
}

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'スペイン倶楽部について', url: '/about-us/' },
];

const missionValues = [
  { Icon: Users, title: '文化交流', text: 'お互いの文化への理解を深め、スペインと日本の絆を育てます。' },
  { Icon: Lightbulb, title: 'アイデアで社会を動かす', text: 'コミュニティに役立つ質の高いコンテンツと体験を届けます。' },
  { Icon: Link2, title: 'つなぐ', text: 'スペイン語話者と日本人の交流の機会を創り出します。' },
  { Icon: Leaf, title: '持続可能な取り組み', text: 'すべての活動において環境と社会への配慮を大切にします。' },
];

const coreValues = [
  { title: 'オープン', text: '国籍・言語・バックグラウンドを問わず、誰でも歓迎します。' },
  { title: '本物志向', text: 'スペインの文化・食・言語を、現地の視点から正確に伝えます。' },
  { title: 'コミュニティファースト', text: 'メンバー一人ひとりの体験が、私たちの活動の中心です。' },
];

const differentiators = [
  { title: '語学 × 文化 × 食 × スポーツ', text: '一つの切り口ではなく、スペインのあらゆる側面を体験できます。' },
  { title: '日本語でスペインを深掘り', text: '日本語を母語とする方も、日本語が堪能なスペイン語話者も、自然に参加できる環境があります。' },
  { title: '東京を拠点に、世界とつながる', text: '東京でのリアルなイベントを中心に、オンラインでも活動を広げています。' },
];

const timeline = [
  { year: '2016', text: '日本で出会った仲間たち。スペイン語を話す友人たちが東京に集まり、自然とコミュニティが生まれ始めました。' },
  { year: '2018', text: 'Club Español en Japón スペイン倶楽部を正式に創設。文化と料理への情熱から、イベントや活動を本格的にスタートしました。' },
  { year: '2019', text: '創設1年で46のイベントを開催。年末には日本とスペインで1,400名以上のメンバーが集まるコミュニティに成長しました。' },
  { year: '2020', text: '東京でのイベント活動を継続。クラブ2周年を仲間たちと祝いました。' },
  { year: '2022', text: 'パエリア・タパスフェスティバルをはじめ、レアル・マドリード財団との協力など、活動の幅をさらに広げました。' },
  { year: '2026', text: 'スペインに関する日本語ポータルサイト supein.club をリニューアル。コンテンツを通じて、より多くの日本人にスペインの魅力を届けます。' },
];

const tocHeadings = [
  { depth: 2, slug: 'mission', text: '私たちのミッション' },
  { depth: 2, slug: 'values', text: '大切にしていること' },
  { depth: 2, slug: 'features', text: '人を中心に考えるコミュニティ' },
  { depth: 2, slug: 'story', text: 'はじまりの物語' },
  { depth: 2, slug: 'logo', text: 'ロゴの由来' },
];

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'スペイン倶楽部について | supein.club',
  url: 'https://supein.club/about-us/',
  description: 'Club Español en Japón スペイン倶楽部のミッション・活動・歴史について。',
  mainEntity: {
    '@type': 'Organization',
    name: 'スペイン倶楽部 (Club Español en Japón)',
    url: 'https://supein.club',
    foundingDate: '2018',
    description: '日本在住のスペイン語話者・スペイン好きが集まる東京発のコミュニティ。',
    address: { '@type': 'PostalAddress', addressLocality: '東京', addressCountry: 'JP' },
    sameAs: [
      'https://www.instagram.com/supeinclub/',
      'https://www.facebook.com/supeinclub/',
      'https://twitter.com/supeinclub',
      'https://lin.ee/vx6jpud',
    ],
  },
};
---

<BaseLayout>
  <SEO
    slot="seo"
    title="スペイン倶楽部について | supein.club"
    description="Club Español en Japón スペイン倶楽部は、日本と日本に在住するスペイン語話者をつなぐ東京発のコミュニティです。2018年創設、1,786名以上のメンバー。"
    canonical="https://supein.club/about-us/"
    breadcrumbs={breadcrumbs}
  />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} />

  <!-- HERO -->
  <section class="bg-navy text-white py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-4">スペイン倶楽部について</p>
      <h1 class="font-serif text-3xl md:text-5xl font-bold mb-6 leading-tight">
        日本とスペインをつなぐ、<br />東京発のコミュニティ。
      </h1>
      <p class="text-white/75 text-lg leading-relaxed max-w-2xl mb-12">
        2018年の創設以来、私たちはヒスパニックと日本のコミュニティの架け橋として、語学・文化・食・スポーツを通じた交流を続けています。
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { value: '2018年', label: '創設' },
          { value: '1,786+', label: 'メンバー' },
          { value: '東京', label: '拠点' },
          { value: '46+', label: 'イベント/年' },
        ].map(({ value, label }) => (
          <div class="border border-white/15 rounded-xl p-4 text-center">
            <p class="text-white font-bold text-2xl mb-1">{value}</p>
            <p class="text-white/50 text-xs uppercase tracking-wider">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TOC mobile (accordion) — global CSS lo oculta en desktop -->
  <div class="max-w-4xl mx-auto px-4 pt-10">
    <details class="toc-mobile-inline">
      <summary>
        <span>目次</span>
        <span class="tmi-chevron" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </summary>
      <ol class="tmi-list">
        {tocHeadings.map((h, i) => (
          <li>
            <a href={'#' + h.slug}>
              <span class="tmi-num">{i + 1}.</span>
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </details>
  </div>

  <!-- SECCIÓN 1: ミッション -->
  <section id="mission" class="py-20 px-4 bg-canvas">
    <div class="max-w-4xl mx-auto">
      <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-2">OUR MISSION</p>
      <h2 class="font-serif text-3xl font-bold text-navy mb-6">私たちのミッション</h2>
      <p class="text-muted leading-relaxed mb-12 max-w-2xl">
        Club Español en Japón スペイン倶楽部は、日本に住むスペイン語話者と、スペインに興味を持つ日本人をつなぐコミュニティです。語学・文化交流・料理・スポーツ・アウトドアなど、多彩な活動を通じて、両コミュニティの相互理解を深めることを目指しています。
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {missionValues.map(({ Icon, title, text }) => (
          <div class="bg-white rounded-2xl border border-ink/5 p-6 shadow-sm">
            <Icon size={32} class="text-primary mb-3" />
            <h3 class="font-semibold text-navy mb-2">{title}</h3>
            <p class="text-muted text-sm leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCIÓN 2: 価値観 -->
  <section id="values" class="py-20 px-4 bg-navy text-white">
    <div class="max-w-4xl mx-auto">
      <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-2">OUR VALUES</p>
      <h2 class="font-serif text-3xl font-bold mb-12">私たちが大切にしていること</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {coreValues.map(({ title, text }) => (
          <div>
            <h3 class="font-semibold text-white text-lg mb-3 pb-3 border-b border-white/15">{title}</h3>
            <p class="text-white/65 text-sm leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCIÓN 3: 特徴 -->
  <section id="features" class="py-20 px-4 bg-canvas">
    <div class="max-w-4xl mx-auto">
      <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-2">HOW WE'RE DIFFERENT</p>
      <h2 class="font-serif text-3xl font-bold text-navy mb-6">人を中心に考えるコミュニティ</h2>
      <p class="text-muted leading-relaxed mb-12 max-w-2xl">
        多くの語学教室やカルチャースクールとは異なり、私たちは「学ぶこと」だけを目的にしていません。スペイン語を学びながら友達を作り、料理を一緒に楽しみ、スポーツで汗を流す。人と人とのつながりを通じて、スペインをもっと身近に感じてほしい—それが私たちのアプローチです。
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {differentiators.map(({ title, text }) => (
          <div class="bg-white rounded-2xl border border-ink/5 p-6 shadow-sm">
            <h3 class="font-semibold text-navy mb-3 text-sm leading-snug">{title}</h3>
            <p class="text-muted text-sm leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCIÓN 4: はじまりの物語 -->
  <section id="story" class="py-20 px-4" style="background-color:#f8f8f6;">
    <div class="max-w-4xl mx-auto">
      <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-2">OUR STORY</p>
      <h2 class="font-serif text-3xl font-bold text-navy mb-12">はじまりの物語</h2>
      <div class="relative">
        <div class="absolute left-6 top-0 bottom-0 w-px bg-ink/10 hidden md:block"></div>
        <div class="space-y-10">
          {timeline.map(({ year, text }) => (
            <div class="flex gap-4 md:gap-8 items-start">
              <div class="flex-shrink-0 flex flex-col items-center gap-2 w-10 md:w-12">
                <div class="w-3 h-3 rounded-full bg-primary hidden md:block mt-1"></div>
                <span class="font-bold text-primary text-sm">{year}</span>
              </div>
              <p class="text-muted leading-relaxed text-sm pt-0.5">{text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 5: ロゴの由来 -->
  <section id="logo" class="bg-canvas" style="padding-top:80px;padding-bottom:80px;">
    <div class="logo-section-inner">
      <p class="text-primary font-semibold uppercase mb-4" style="font-size:11px;letter-spacing:0.12em;">OUR LOGO</p>
      <h2 class="font-sans font-bold text-navy mb-4 logo-heading">ロゴの由来</h2>
      <p class="text-muted mb-12 logo-subtitle">
        私たちのロゴには、スペインと日本、ふたつの国のアイデンティティが込められています。
      </p>
      <div class="logo-grid">
        <figure style="margin:0;">
          <img
            src="/branding-supeinclub.webp"
            alt="スペイン倶楽部ロゴの由来 — スペイン語のスペイン（España）と日本語の日本を組み合わせたロゴデザイン"
            width="600"
            height="300"
            loading="lazy"
            style="width:100%;height:auto;border-radius:12px;box-shadow:0 4px 24px rgba(0,0,0,0.08);"
          />
        </figure>
        <div>
          <div class="logo-block">
            <div class="logo-icon">
              <Type size={20} />
            </div>
            <div>
              <h3 class="logo-block-title">スペイン（España）</h3>
              <p class="logo-block-text">「スペイン」は、日本語でスペインを意味する言葉です。カタカナで表記することで、日本語話者にとって親しみやすく、かつスペインらしさを表現しています。</p>
            </div>
          </div>
          <div class="logo-block">
            <div class="logo-icon logo-icon-red">
              <Circle size={20} />
            </div>
            <div>
              <h3 class="logo-block-title">日本の魂、日の丸</h3>
              <p class="logo-block-text">ロゴの「ペ」の文字の上に置かれた赤い点は、日本の国旗「日の丸」を象徴しています。スペイン語の「España」と日本語の「日本」——ふたつの国が、ひとつの文字の中でつながっています。</p>
            </div>
          </div>
          <div class="logo-block logo-block-last">
            <div class="logo-icon">
              <Palette size={20} />
            </div>
            <div>
              <h3 class="logo-block-title">ネイビーとレッド</h3>
              <p class="logo-block-text">ネイビーブルーはスペインの夜空と信頼を、レッドはスペインと日本、両国の国旗の色を表しています。このふたつの色が、私たちのアイデンティティの核心です。</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN: チームを知る -->
  <section style="background:#FAFAF8; padding:80px 0;">
    <div class="max-w-4xl mx-auto px-4">
      <p style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#C8102E; margin-bottom:12px;">OUR TEAM</p>
      <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,36px); margin-bottom:16px;">チームメンバー</h2>
      <p style="font-size:17px; color:#6b7280; line-height:1.8; max-width:560px; margin-bottom:48px;">
        スペイン倶楽部のコンテンツを支える編集・制作チームをご紹介します。
      </p>
      <div class="team-mini-grid">
        {featuredAuthors.map((author) => {
          const slug = teamSlug(author);
          return (
            <a href={`/about-us/team/${slug}/`} class="team-mini-card">
              <div class="mini-banner">
                {author.data.avatar ? (
                  <img
                    src={author.data.avatar}
                    alt={author.data.name}
                    width="88"
                    height="88"
                    class="mini-avatar"
                    loading="lazy"
                  />
                ) : (
                  <div class="mini-avatar mini-avatar-placeholder">
                    {author.data.name.slice(0, 1)}
                  </div>
                )}
              </div>
              <div class="mini-body">
                <p class="mini-name">{author.data.nameJa ?? author.data.name}</p>
                {author.data.nameJa && (
                  <p class="mini-romaji">{author.data.name}</p>
                )}
                {(author.data.role ?? author.data.jobTitle) && (
                  <span class="mini-role">{author.data.role ?? author.data.jobTitle}</span>
                )}
                <p class="mini-bio">{author.data.bio}</p>
                <span class="mini-cta">プロフィールを見る →</span>
              </div>
            </a>
          );
        })}
      </div>
      <div style="text-align:center; margin-top:40px;">
        <a
          href="/about-us/team/"
          style="display:inline-flex; align-items:center; gap:8px; color:#002147; font-weight:600; border:2px solid #002147; padding:12px 28px; border-radius:8px; text-decoration:none; font-size:15px; transition:background 200ms, color 200ms;"
          onmouseover="this.style.background='#002147';this.style.color='white'"
          onmouseout="this.style.background='transparent';this.style.color='#002147'"
        >
          チーム全員を見る →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-primary py-16 px-4 text-white text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="font-serif text-2xl md:text-3xl font-bold mb-4">スペイン倶楽部のメンバーになりませんか？</h2>
      <p class="text-white/80 leading-relaxed mb-8">
        LINEで友だち追加するだけで、イベント情報・お役立ちコンテンツをいち早くお届けします。
      </p>
      <a
        href="https://lin.ee/vx6jpud"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-white text-primary font-bold px-8 py-4 rounded-full text-lg hover:bg-white/90 transition-colors"
      >
        LINEで参加する
      </a>
    </div>
  </section>

  <LineBanner />
</BaseLayout>

<style>
  .logo-section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .logo-heading {
    font-size: 36px;
    line-height: 1.2;
  }

  .logo-subtitle {
    font-size: 18px;
    line-height: 1.7;
    max-width: 600px;
  }

  .logo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .logo-block {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
  }

  .logo-block-last {
    margin-bottom: 0;
  }

  .logo-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: rgba(200, 16, 46, 0.08);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #C8102E;
  }

  .logo-block-title {
    font-weight: 700;
    color: #002147;
    font-size: 16px;
    margin-bottom: 8px;
  }

  .logo-block-text {
    color: #6b7280;
    font-size: 15px;
    line-height: 1.8;
  }

  @media (max-width: 767px) {
    .logo-heading {
      font-size: 24px;
    }

    .logo-subtitle {
      font-size: 16px;
    }

    .logo-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .team-mini-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .team-mini-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    display: block;
    transition: transform 250ms ease, box-shadow 250ms ease;
  }
  .team-mini-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .mini-banner {
    background: #002147;
    height: 72px;
    position: relative;
    margin-bottom: 44px;
  }

  .mini-avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid white;
    position: absolute;
    bottom: -44px;
    left: 50%;
    transform: translateX(-50%);
  }

  .mini-avatar-placeholder {
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    font-weight: 700;
    color: white;
  }

  .mini-body {
    padding: 0 20px 24px;
    text-align: center;
  }

  .mini-name {
    font-size: 18px;
    font-weight: 700;
    color: #002147;
    margin: 0 0 3px;
  }

  .mini-romaji {
    font-size: 12px;
    color: #9ca3af;
    margin: 0 0 10px;
  }

  .mini-role {
    display: inline-block;
    background: rgba(200, 16, 46, 0.08);
    color: #C8102E;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 14px;
  }

  .mini-bio {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.7;
    margin: 0 0 16px;
  }

  .mini-cta {
    color: #C8102E;
    font-size: 13px;
    font-weight: 600;
  }

  @media (max-width: 767px) {
    .team-mini-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
