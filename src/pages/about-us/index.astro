---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import LineBanner from '../../components/LineBanner.astro';
---
<BaseLayout>
  <SEO slot="seo" title="スペイン倶楽部について | supein.club" description="Club Español en Japón（スペイン倶楽部）の紹介。日本在住のスペイン語話者・スペイン好きが集まるコミュニティです。" canonical="https://supein.club/about-us/" />
  <section class="bg-navy text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">スペイン倶楽部について</h1>
      <p class="text-white/80 text-lg">Club Español en Japón — 日本のスペイン語コミュニティ</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 py-12 space-y-8">
    <div>
      <h2 class="font-serif text-2xl font-bold text-navy mb-3">私たちについて</h2>
      <p class="text-muted leading-relaxed">Club Español en Japón（スペイン倶楽部）は、日本在住のスペイン語話者・スペイン文化に興味を持つ方が集まるコミュニティです。語学イベント、文化交流、料理会など多彩な活動を定期開催しています。</p>
    </div>
    <div>
      <h2 class="font-serif text-2xl font-bold text-navy mb-3">主な活動</h2>
      <ul class="list-disc list-inside text-muted space-y-2 leading-relaxed">
        <li>スペイン語・日本語の言語交換イベント</li>
        <li>スペイン料理パーティー・ワイン会</li>
        <li>フラメンコ・映画鑑賞などの文化イベント</li>
        <li>スペイン旅行の情報共有</li>
      </ul>
    </div>
  </section>
  <LineBanner />
</BaseLayout>
