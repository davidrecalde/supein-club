---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import LineBanner from '../../../components/LineBanner.astro';
import { Globe } from 'lucide-astro';

const allAuthors = await getCollection('authors', ({ data }) => data.active !== false);
function byOrder(a: typeof allAuthors[number], b: typeof allAuthors[number]) {
  return (a.data.order ?? 999) - (b.data.order ?? 999);
}
const featured = allAuthors.filter((a) => a.data.featured).sort(byOrder);
const rest = allAuthors.filter((a) => !a.data.featured).sort(byOrder);
const authors = [...featured, ...rest];

const canonical = 'https://supein.club/about-us/team/';

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'スペイン倶楽部とは', url: '/about-us/' },
  { name: 'チームメンバー', url: '' },
];

const teamSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'チームメンバー | スペイン倶楽部',
  url: canonical,
  description: 'スペイン倶楽部の編集チームをご紹介します。スペインと日本の架け橋として活動するメンバーが、ガストロノミー・旅行・文化を日本語で発信しています。',
  mainEntity: {
    '@type': 'Organization',
    name: 'Club Español en Japón スペイン倶楽部',
    url: 'https://supein.club',
    member: authors.map((a) => ({
      '@type': 'Person',
      name: a.data.name,
      alternateName: a.data.nameJa ?? undefined,
      jobTitle: a.data.role ?? a.data.jobTitle ?? undefined,
      image: a.data.avatar ? `https://supein.club${a.data.avatar}` : undefined,
      url: `https://supein.club/about-us/team/${a.data.slug ?? a.id.replace(/\.(md|mdx)$/, '')}/`,
    })),
  },
});

function authorSlug(author: typeof authors[number]) {
  return author.data.slug ?? author.id.replace(/\.(md|mdx)$/, '');
}

function socialUrl(val: string | undefined, base: string): string | undefined {
  if (!val) return undefined;
  return val.startsWith('http') ? val : `${base}${val}`;
}
---

<BaseLayout title="チームメンバー | スペイン倶楽部">
  <SEO
    slot="seo"
    title="チームメンバー | スペイン倶楽部 — Club Español en Japón"
    description="スペイン倶楽部の編集チームをご紹介します。スペインと日本の架け橋として活動するメンバーが、ガストロノミー・旅行・文化を日本語で発信しています。"
    canonical={canonical}
    breadcrumbs={breadcrumbs}
  />
  <script type="application/ld+json" slot="head" set:html={teamSchema} />

  <!-- HERO -->
  <section class="bg-navy text-white relative" style="padding:80px 0;">
    <div class="absolute top-0 left-0 right-0 h-[3px] bg-primary"></div>
    <div class="container">
      <div style="margin-bottom:28px; opacity:0.6;">
        <Breadcrumb items={breadcrumbs} dark={true} />
      </div>
      <p style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#C8102E; margin-bottom:12px;">OUR TEAM</p>
      <h1 class="font-serif font-bold text-white" style="font-size:clamp(32px,5vw,48px); line-height:1.2; margin-bottom:20px;">
        チームメンバー
      </h1>
      <p style="font-size:18px; color:rgba(255,255,255,0.75); line-height:1.8; max-width:600px; margin:0;">
        スペイン倶楽部の編集・制作チームをご紹介します。<br />
        スペインと日本の架け橋として、ガストロノミー、旅行、<br />
        文化を日本語で発信しています。
      </p>
    </div>
  </section>

  <!-- SECCIÓN: Grid de autores -->
  <section style="background:var(--color-canvas); padding:80px 0;">
    <div class="container">
      <div class="team-grid">
        {authors.map((author) => {
          const slug = authorSlug(author);
          const displayName = author.data.nameJa ?? author.data.name;
          const romajiName = author.data.nameJa ? author.data.name : undefined;
          const displayRole = author.data.role ?? author.data.jobTitle ?? '';
          const skills = (author.data.specialties ?? author.data.knowsAbout ?? []).slice(0, 3);
          const linkedinUrl = socialUrl(author.data.linkedin, 'https://linkedin.com/in/');
          const instagramUrl = socialUrl(author.data.instagram, 'https://instagram.com/');
          const websiteUrl = author.data.website;
          const hasSocials = linkedinUrl || instagramUrl || websiteUrl;
          return (
            <article class="team-card">
              <!-- Banda navy + avatar flotante -->
              <div class="card-banner">
                {author.data.avatar ? (
                  <img
                    src={author.data.avatar}
                    alt={author.data.name}
                    width="96"
                    height="96"
                    class="card-avatar"
                    loading="lazy"
                  />
                ) : (
                  <div class="card-avatar card-avatar-placeholder">
                    {author.data.name.slice(0, 1)}
                  </div>
                )}
              </div>

              <!-- Contenido -->
              <div class="card-body">
                <h2 class="card-name">{displayName}</h2>
                {romajiName && <p class="card-romaji">{romajiName}</p>}
                {displayRole && <span class="card-role">{displayRole}</span>}

                <p class="card-bio">{author.data.bio}</p>

                {skills.length > 0 && (
                  <div class="card-skills">
                    {skills.map((s) => (
                      <span class="card-skill">{s}</span>
                    ))}
                  </div>
                )}

                {hasSocials && (
                  <div class="card-socials">
                    {linkedinUrl && (
                      <a href={linkedinUrl} target="_blank" rel="noopener noreferrer nofollow" class="card-social-icon" aria-label="LinkedIn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                      </a>
                    )}
                    {instagramUrl && (
                      <a href={instagramUrl} target="_blank" rel="noopener noreferrer nofollow" class="card-social-icon" aria-label="Instagram">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                        </svg>
                      </a>
                    )}
                    {websiteUrl && (
                      <a href={websiteUrl} target="_blank" rel="noopener noreferrer" class="card-social-icon" aria-label="ウェブサイト">
                        <Globe size={18} />
                      </a>
                    )}
                  </div>
                )}

                <a href={`/about-us/team/${slug}/`} class="card-cta">
                  プロフィールを見る →
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- SECCIÓN: Colaborar -->
  <section class="bg-navy text-white" style="padding:72px 0; text-align:center;">
    <div class="container" style="max-width:600px;">
      <p style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#C8102E; margin-bottom:12px;">JOIN US</p>
      <h2 class="font-serif font-bold text-white" style="font-size:clamp(22px,3vw,32px); margin-bottom:20px;">
        ライター・コラボレーター募集
      </h2>
      <p style="font-size:16px; color:rgba(255,255,255,0.75); line-height:1.8; max-width:560px; margin:0 auto 32px;">
        スペインと日本をつなぐコンテンツを一緒に作りませんか。<br />
        スペイン語話者、スペイン在住・在住経験者、<br />
        スペイン料理・旅行・文化の専門家を歓迎します。
      </p>
      <a
        href="/contact/"
        class="bg-primary hover:bg-red-dark text-white font-bold rounded-lg transition-colors"
        style="padding:14px 32px; font-size:15px; text-decoration:none; display:inline-block;"
      >
        お問い合わせはこちら →
      </a>
    </div>
  </section>

  <LineBanner />
</BaseLayout>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .team-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
    transition: transform 300ms ease, box-shadow 300ms ease;
  }
  .team-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.10);
  }

  .card-banner {
    background: #002147;
    height: 80px;
    position: relative;
    margin-bottom: 48px;
  }

  .card-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid white;
    position: absolute;
    bottom: -48px;
    left: 50%;
    transform: translateX(-50%);
  }

  .card-avatar-placeholder {
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    font-weight: 700;
    color: white;
  }

  .card-body {
    padding: 0 24px 28px;
    text-align: center;
  }

  .card-name {
    font-size: 20px;
    font-weight: 700;
    color: #002147;
    margin: 0 0 4px;
  }

  .card-romaji {
    font-size: 13px;
    color: #9ca3af;
    margin: 0 0 12px;
  }

  .card-role {
    display: inline-block;
    background: rgba(200, 16, 46, 0.08);
    color: #C8102E;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 4px;
    margin-bottom: 16px;
  }

  .card-bio {
    font-size: 14px;
    color: #6b7280;
    line-height: 1.7;
    margin: 0 0 20px;
  }

  .card-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-bottom: 20px;
  }

  .card-skill {
    font-size: 11px;
    color: #374151;
    background: #f3f4f6;
    padding: 3px 10px;
    border-radius: 4px;
  }

  .card-socials {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-bottom: 20px;
  }

  .card-social-icon {
    color: #9ca3af;
    display: flex;
    align-items: center;
    transition: color 200ms ease;
  }
  .card-social-icon:hover {
    color: #002147;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: #C8102E;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 200ms ease;
  }
  .card-cta:hover {
    opacity: 0.75;
  }

  @media (max-width: 1023px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 639px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
