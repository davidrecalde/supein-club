---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import LineBanner from '../../../components/LineBanner.astro';
import { Globe } from 'lucide-astro';

export async function getStaticPaths() {
  const authors = await getCollection('authors', ({ data }) => data.active !== false);
  return authors.map((author) => ({
    params: { slug: author.data.slug ?? author.id.replace(/\.(md|mdx)$/, '') },
    props: { author },
  }));
}

interface Props {
  author: CollectionEntry<'authors'>;
}

const { author } = Astro.props;
const { Content } = await author.render();

const slug = author.data.slug ?? author.id.replace(/\.(md|mdx)$/, '');
const {
  name, nameJa, role, jobTitle, avatar, bio, bioLong,
  location, since, linkedin, website, websiteLabel, instagram, twitter,
  specialties, knowsAbout,
} = author.data;

const displayName = nameJa ?? name;
const displayRole = role ?? jobTitle ?? '';
const skills = specialties ?? knowsAbout ?? [];

const linkedinUrl = linkedin?.startsWith('http') ? linkedin : (linkedin ? `https://linkedin.com/in/${linkedin}` : undefined);
const instagramUrl = instagram?.startsWith('http') ? instagram : (instagram ? `https://instagram.com/${instagram}` : undefined);
const websiteUrl = website;

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const articles = allArticles
  .filter((a) => {
    const ref = a.data.author;
    const refId = typeof ref === 'object' && 'id' in ref ? ref.id : String(ref);
    return refId === author.id || refId === author.id.replace(/\.(md|mdx)$/, '');
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const authorUrl = `https://supein.club/about-us/team/${slug}/`;

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'スペイン倶楽部とは', url: '/about-us/' },
  { name: 'チームメンバー', url: '/about-us/team/' },
  { name: displayName, url: '' },
];

const sameAs = [linkedinUrl, websiteUrl, instagramUrl].filter(Boolean) as string[];

const profileSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  dateCreated: '2026-06-01T00:00:00Z',
  dateModified: new Date().toISOString(),
  mainEntity: {
    '@type': 'Person',
    name,
    alternateName: nameJa ?? undefined,
    jobTitle: displayRole || undefined,
    description: bio,
    image: avatar ? {
      '@type': 'ImageObject',
      url: `https://supein.club${avatar}`,
      width: 400,
      height: 400,
    } : undefined,
    url: authorUrl,
    sameAs: sameAs.length > 0 ? sameAs : undefined,
    worksFor: {
      '@type': 'Organization',
      name: 'Club Español en Japón スペイン倶楽部',
      url: 'https://supein.club',
    },
  },
};

const hasBio = author.body?.trim().length > 0;
---

<BaseLayout title={`${displayName} | supein.club`}>
  <SEO
    slot="seo"
    title={`${displayName}${displayRole ? ' — ' + displayRole : ''} | supein.club`}
    description={bio}
    canonical={authorUrl}
    breadcrumbs={breadcrumbs}
  />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(profileSchema)} />

  <!-- HERO -->
  <section class="bg-navy text-white relative" style="padding: 80px 0;">
    <div class="absolute top-0 left-0 right-0 h-[3px] bg-primary"></div>
    <div class="container">
      <div style="margin-bottom: 32px; opacity: 0.6;">
        <Breadcrumb items={breadcrumbs} dark={true} />
      </div>

      <div class="author-hero-grid">

        <!-- Foto -->
        <figure style="text-align:center; margin:0;">
          {avatar ? (
            <img
              src={avatar}
              alt={name}
              width="220"
              height="220"
              style="width:220px; height:220px; object-fit:cover; border-radius:50%; border:4px solid rgba(255,255,255,0.15); display:block; margin:0 auto;"
              loading="eager"
            />
          ) : (
            <div style="width:220px; height:220px; border-radius:50%; background:rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; margin:0 auto; font-size:64px; font-weight:700; color:white;">
              {name.slice(0, 1)}
            </div>
          )}
        </figure>

        <!-- Info -->
        <div class="author-hero-info">
          <p style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#C8102E; margin-bottom:12px;">AUTHOR</p>

          <h1 class="font-serif font-bold text-white" style="font-size:clamp(32px,5vw,48px); line-height:1.2; margin-bottom:8px;">
            {displayName}
          </h1>

          {nameJa && name !== displayName && (
            <p style="font-size:18px; color:rgba(255,255,255,0.5); margin-bottom:16px;">{name}</p>
          )}

          {displayRole && (
            <div style="display:inline-block; border:1px solid rgba(255,255,255,0.2); border-radius:6px; padding:6px 14px; font-size:13px; color:white; margin-bottom:24px;">
              {displayRole}
            </div>
          )}

          <!-- Metadata pills -->
          {(location || since) && (
            <div style="display:flex; flex-wrap:wrap; gap:16px; margin-bottom:24px;">
              {location && (
                <span style="font-size:14px; color:rgba(255,255,255,0.7);">📍 {location}</span>
              )}
              {since && (
                <span style="font-size:14px; color:rgba(255,255,255,0.7);">📅 {since}年から</span>
              )}
            </div>
          )}

          <!-- Bio corta -->
          <p style="font-size:17px; color:rgba(255,255,255,0.75); line-height:1.8; max-width:520px; margin-bottom:28px;">
            {bio}
          </p>

          <!-- Especialidades -->
          {skills.length > 0 && (
            <div style="margin-bottom:28px;">
              <p style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin-bottom:10px;">
                専門分野
              </p>
              <div style="display:flex; flex-wrap:wrap; gap:8px;">
                {skills.map((s) => (
                  <span style="font-size:12px; padding:4px 12px; border-radius:4px; background:rgba(200,16,46,0.25); color:white; border:1px solid rgba(200,16,46,0.3);">
                    {s}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Redes sociales -->
          {(linkedinUrl || websiteUrl || instagramUrl) && (
            <div style="display:flex; flex-wrap:wrap; gap:12px;">
              {linkedinUrl && (
                <a href={linkedinUrl} target="_blank" rel="noopener noreferrer nofollow" class="social-btn">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn
                </a>
              )}
              {websiteUrl && (
                <a href={websiteUrl} target="_blank" rel="noopener noreferrer" class="social-btn">
                  <Globe size={18} />
                  {websiteLabel ?? "ウェブサイト"}
                </a>
              )}
              {instagramUrl && (
                <a href={instagramUrl} target="_blank" rel="noopener noreferrer nofollow" class="social-btn">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                  Instagram
                </a>
              )}
            </div>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- SECCIÓN: Biografía completa -->
  <section style="background:var(--color-canvas); padding:80px 0;">
    <div class="container" style="max-width:800px;">
      <p style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#C8102E; margin-bottom:8px;">PROFILE</p>
      <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,32px); margin-bottom:40px;">プロフィール</h2>

      {hasBio ? (
        <div class="author-bio-prose">
          <Content />
        </div>
      ) : (
        <p style="font-size:17px; line-height:1.9; color:#374151;">
          {bioLong ?? bio}
        </p>
      )}
    </div>
  </section>

  <!-- SECCIÓN: Artículos -->
  <section style="background:white; padding:72px 0;">
    <div class="container">
      <p style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#C8102E; margin-bottom:8px;">ARTICLES</p>
      <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,32px); margin-bottom:40px;">執筆記事</h2>

      {articles.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {articles.map((a) => {
            const parts = a.id.replace(/\.(md|mdx)$/, '').split('/');
            const articleSlug = parts[2] ?? a.data.cluster;
            return (
              <ArticleCard
                title={a.data.title}
                description={a.data.description}
                href={`/${a.data.pillar}/${a.data.cluster}/${articleSlug}/`}
                pillar={a.data.pillar}
                image={a.data.image}
                imageAlt={a.data.imageAlt}
                pubDate={a.data.pubDate}
              />
            );
          })}
        </div>
      ) : (
        <p class="text-muted text-center" style="padding:48px 0;">記事を準備中です。近日公開予定。</p>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy text-white" style="padding:60px 0; text-align:center;">
    <div class="container" style="max-width:600px;">
      <h2 class="font-serif font-bold text-white" style="font-size:clamp(20px,3vw,28px); margin-bottom:16px;">
        スペイン倶楽部のコミュニティに参加しませんか
      </h2>
      <p style="font-size:16px; color:rgba(255,255,255,0.7); line-height:1.8; margin-bottom:32px;">
        LINEで友だち追加するだけで、最新情報をお届けします。
      </p>
      <a
        href="https://lin.ee/vx6jpud"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-primary hover:bg-red-dark text-white font-bold rounded-lg transition-colors"
        style="padding:14px 32px; font-size:16px; text-decoration:none; display:inline-block;"
      >
        LINEで参加する
      </a>
    </div>
  </section>

  <LineBanner />
</BaseLayout>

<style>
  .author-hero-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 56px;
    align-items: start;
  }
  .author-hero-info {
    padding-top: 8px;
  }
  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: white;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: background 200ms ease;
  }
  .social-btn:hover {
    background: rgba(255, 255, 255, 0.2);
  }
  .author-bio-prose :global(p) {
    font-size: 17px;
    line-height: 1.9;
    color: #374151;
    margin-bottom: 24px;
  }
  .author-bio-prose :global(p:last-child) {
    margin-bottom: 0;
  }
  @media (max-width: 767px) {
    .author-hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      text-align: center;
    }
    .author-hero-info {
      padding-top: 0;
      text-align: left;
    }
  }
</style>
