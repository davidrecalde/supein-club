---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import LineBanner from '../../components/LineBanner.astro';
import { Clock } from 'lucide-astro';

const canonical = 'https://supein.club/contact/';

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'お問い合わせ', url: '' },
];

const contactPageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'お問い合わせ | スペイン倶楽部',
  url: canonical,
  description: 'スペイン倶楽部へのお問い合わせフォーム',
  publisher: {
    '@type': 'Organization',
    name: 'Club Español en Japón スペイン倶楽部',
    url: 'https://supein.club',
  },
});
---
<BaseLayout>
  <SEO
    slot="seo"
    title="お問い合わせ | スペイン倶楽部"
    description="スペイン倶楽部へのお問い合わせフォーム。コラボレーション、メディア掲載、一般のご質問など、お気軽にご連絡ください。"
    canonical={canonical}
    breadcrumbs={breadcrumbs}
  />
  <script type="application/ld+json" slot="head" set:html={contactPageSchema} />

  <!-- HERO -->
  <section class="bg-navy text-white relative" style="padding: 72px 0;">
    <div class="absolute top-0 left-0 right-0 h-[3px] bg-primary"></div>
    <div class="page-container">
      <div style="margin-bottom: 28px; opacity: 0.6;">
        <Breadcrumb items={breadcrumbs} dark />
      </div>
      <p style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #C8102E; margin-bottom: 16px;">
        CONTACT
      </p>
      <h1 class="font-serif font-bold text-white" style="font-size: clamp(32px, 5vw, 48px); line-height: 1.2; margin-bottom: 20px;">
        お問い合わせ
      </h1>
      <p style="font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.8; max-width: 520px; margin: 0;">
        ご質問・コラボレーションのご提案・<br class="hidden-mobile">
        メディア掲載のご依頼など、<br class="hidden-mobile">
        お気軽にご連絡ください。
      </p>
    </div>
  </section>

  <!-- MAIN SECTION -->
  <section style="background: #FAFAF8; padding: 80px 0;">
    <div class="page-container">
      <div class="contact-grid">

        <!-- LEFT: Form -->
        <div style="background: white; border-radius: 16px; padding: 40px; border: 1px solid #e5e7eb;">
          <p style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #C8102E; margin-bottom: 12px;">
            SEND A MESSAGE
          </p>
          <h2 class="font-serif font-bold" style="color: #002147; font-size: 24px; margin-bottom: 32px;">
            メッセージを送る
          </h2>

          <div id="contact-form">

            <div class="form-group">
              <label for="name">お名前 <span style="color:#C8102E">*</span></label>
              <input type="text" id="name" name="name" placeholder="山田 太郎" required />
            </div>

            <div class="form-group">
              <label for="email">メールアドレス <span style="color:#C8102E">*</span></label>
              <input type="email" id="email" name="email" placeholder="your@email.com" required />
            </div>

            <div class="form-group">
              <label for="subject">件名 <span style="color:#C8102E">*</span></label>
              <div style="position:relative;">
                <select id="subject" name="subject" required>
                  <option value="" disabled selected>お問い合わせの種類を選択</option>
                  <option value="コラボレーション">コラボレーション・提携</option>
                  <option value="スポンサーシップ">スポンサーシップ</option>
                  <option value="メディア・取材">メディア・取材</option>
                  <option value="イベント">イベントについて</option>
                  <option value="一般のお問い合わせ">一般のお問い合わせ</option>
                  <option value="その他">その他</option>
                </select>
                <span style="position:absolute;right:14px;top:50%;transform:translateY(-50%);pointer-events:none;color:#9ca3af;">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
            </div>

            <div class="form-group">
              <label for="message">メッセージ <span style="color:#C8102E">*</span></label>
              <textarea id="message" name="message" rows="6" placeholder="こちらにメッセージをご記入ください..."></textarea>
            </div>

            <button
              type="button"
              id="submit-btn"
              onclick="submitContactForm()"
              style="width:100%;background:#C8102E;color:white;border:none;border-radius:8px;padding:16px 24px;font-size:16px;font-weight:600;cursor:pointer;font-family:inherit;transition:background 200ms;"
              onmouseover="this.style.background='#a50d26'"
              onmouseout="this.style.background='#C8102E'"
            >
              送信する →
            </button>

            <div id="form-sending" style="display:none;text-align:center;padding:20px;color:#6b7280;">
              送信中...
            </div>

            <div id="form-success" style="display:none;background:#f0fdf4;border:1px solid #86efac;border-radius:8px;padding:24px;text-align:center;margin-top:16px;">
              <p style="color:#166534;font-weight:600;font-size:16px;margin:0 0 8px;">✓ メッセージを送信しました</p>
              <p style="color:#15803d;font-size:14px;margin:0;">通常2〜3営業日以内にご返信いたします。</p>
            </div>

            <div id="form-error" style="display:none;background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:24px;text-align:center;margin-top:16px;">
              <p style="color:#991b1b;font-weight:600;font-size:14px;margin:0;">
                送信に失敗しました。時間をおいて再度お試しください。
              </p>
            </div>

          </div>
        </div>

        <!-- RIGHT: Info sidebar -->
        <div class="contact-sidebar">

          <!-- SNS block -->
          <div style="margin-bottom: 32px;">
            <p style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #C8102E; margin-bottom: 8px;">
              SNS
            </p>
            <h3 style="font-size: 16px; font-weight: 700; color: #002147; margin-bottom: 20px;">
              SNS・ソーシャルメディア
            </h3>

            <a
              href="https://www.linkedin.com/company/supeinclub/"
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="sns-link"
              onmouseover="this.style.borderColor='#002147';this.style.transform='translateY(-1px)'"
              onmouseout="this.style.borderColor='#e5e7eb';this.style.transform='translateY(0)'"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#002147" aria-hidden="true" style="flex-shrink:0;">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <div>
                <p style="font-weight:600;font-size:14px;margin:0;color:#002147;">LinkedIn</p>
                <p style="color:#9ca3af;font-size:12px;margin:0;">@supeinclub</p>
              </div>
            </a>

            <a
              href="https://www.instagram.com/supeinclub/"
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="sns-link"
              onmouseover="this.style.borderColor='#dc2743';this.style.transform='translateY(-1px)'"
              onmouseout="this.style.borderColor='#e5e7eb';this.style.transform='translateY(0)'"
            >
              <div style="width:32px;height:32px;border-radius:8px;background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </div>
              <div>
                <p style="font-weight:600;font-size:14px;margin:0;color:#002147;">Instagram</p>
                <p style="color:#9ca3af;font-size:12px;margin:0;">@supeinclub</p>
              </div>
            </a>
          </div>

          <!-- Response time block -->
          <div style="background:rgba(200,16,46,0.04);border:1px solid rgba(200,16,46,0.15);border-radius:10px;padding:20px;">
            <div style="display:flex;align-items:flex-start;gap:10px;">
              <Clock size={16} color="#C8102E" style="flex-shrink:0;margin-top:2px;" />
              <p style="font-size:13px;color:#374151;margin:0;line-height:1.6;">
                <strong style="color:#002147;">返信時間</strong><br>
                通常2〜3営業日以内にご返信いたします。
                イベント開催期間中は返信が遅れる場合があります。
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <LineBanner />
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 64px;
    align-items: start;
  }

  .contact-sidebar {
    position: sticky;
    top: 80px;
  }

  .sns-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    margin-bottom: 12px;
    text-decoration: none;
    color: #002147;
    background: white;
    transition: border-color 200ms, transform 150ms;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #002147;
    margin-bottom: 6px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    font-size: 15px;
    font-family: inherit;
    color: #374151;
    background: white;
    transition: border-color 200ms;
    box-sizing: border-box;
    appearance: none;
    -webkit-appearance: none;
  }

  .form-group select {
    padding-right: 40px;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #C8102E;
    box-shadow: 0 0 0 3px rgba(200,16,46,0.08);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #9ca3af;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  @media (max-width: 767px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .contact-sidebar {
      position: static;
    }

    .hidden-mobile {
      display: none;
    }
  }
</style>

<script>
  // ⚠️ PENDIENTE: Reemplazar 'TU_ACCESS_KEY_AQUI'
  // con el Access Key de web3forms.com
  // Registrarse en https://web3forms.com con clubsupein@gmail.com

  async function submitContactForm() {
    const nameEl = document.getElementById('name') as HTMLInputElement;
    const emailEl = document.getElementById('email') as HTMLInputElement;
    const subjectEl = document.getElementById('subject') as HTMLSelectElement;
    const messageEl = document.getElementById('message') as HTMLTextAreaElement;

    const name = nameEl.value.trim();
    const email = emailEl.value.trim();
    const subject = subjectEl.value;
    const message = messageEl.value.trim();

    if (!name || !email || !subject || !message) {
      alert('すべての項目を入力してください。');
      return;
    }

    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const sendingEl = document.getElementById('form-sending') as HTMLElement;
    const successEl = document.getElementById('form-success') as HTMLElement;
    const errorEl = document.getElementById('form-error') as HTMLElement;

    submitBtn.style.display = 'none';
    sendingEl.style.display = 'block';
    errorEl.style.display = 'none';

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          access_key: 'TU_ACCESS_KEY_AQUI',
          name,
          email,
          subject: '【スペイン倶楽部】' + subject,
          message,
          from_name: 'supein.club お問い合わせフォーム',
          botcheck: '',
        }),
      });

      const data = await response.json();

      sendingEl.style.display = 'none';

      if (data.success) {
        successEl.style.display = 'block';
        nameEl.value = '';
        emailEl.value = '';
        subjectEl.value = '';
        messageEl.value = '';
      } else {
        errorEl.style.display = 'block';
        submitBtn.style.display = 'block';
      }
    } catch {
      sendingEl.style.display = 'none';
      errorEl.style.display = 'block';
      submitBtn.style.display = 'block';
    }
  }

  (window as any).submitContactForm = submitContactForm;
</script>
