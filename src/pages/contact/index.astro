---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import LineBanner from '../../components/LineBanner.astro';

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'お問い合わせ', url: '/contact/' },
];
---
<BaseLayout>
  <SEO slot="seo" title="お問い合わせ | supein.club" description="supein.club・スペイン倶楽部へのお問い合わせはこちら。スペイン語レッスン・旅行相談・留学サポートなどお気軽にどうぞ。" canonical="https://supein.club/contact/" breadcrumbs={breadcrumbs} />
  <section class="bg-navy text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-4">お問い合わせ</h1>
      <p class="text-white/80 text-lg">スペイン倶楽部へのご連絡はLINEが最も早くてかんたんです</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-white rounded-2xl shadow-sm border border-ink/5 p-8 text-center">
      <p class="text-6xl mb-6">💬</p>
      <h2 class="font-serif text-2xl font-bold text-navy mb-4">LINEでお気軽に</h2>
      <p class="text-muted leading-relaxed max-w-xl mx-auto mb-8">
        スペイン語レッスン・旅行相談・留学サポートなど、どんなことでもお気軽にお問い合わせください。
        通常24時間以内にご返信します。
      </p>
      <a
        href="https://lin.ee/vx6jpud"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-[#06C755] hover:bg-[#05b34d] text-white font-bold px-8 py-4 rounded-full text-lg transition-colors"
      >
        LINE で友達追加
      </a>
    </div>
  </section>
  <LineBanner />
</BaseLayout>
