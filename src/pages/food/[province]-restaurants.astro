---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ProvinceGuideLayout from '../../layouts/ProvinceGuideLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('spain-map', ({ data }) => data.draft !== true);
  return entries.map((entry) => ({
    params: { province: entry.data.province },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'spain-map'>;
}

const { entry } = Astro.props;
---
<ProvinceGuideLayout entry={entry} />
