---
<BaseLayout title="スペイン美食地図 | supein.club">
  <SEO
    slot="seo"
    title="スペイン美食地図 — 味で旅するスペイン | supein.club"
    description="50省・7つの美食ゾーンで探す、本場スペインのグルメ体験。スペイン倶楽部が厳選したレストラン・バルマップ。バスクのピンチョスからアンダルシアのガスパチョまで。"
    canonical={canonical}
    breadcrumbs={breadcrumbs}
  />

  <!-- Hero -->
  <section class="bg-navy text-white relative" style="padding:80px 0;">
    <div class="absolute top-0 left-0 right-0 h-[3px] bg-primary"></div>
    <div class="container">
      <div style="margin-bottom:20px; opacity:0.5;">
        <Breadcrumb items={breadcrumbs} dark={true} />
      </div>
      <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:12px;">SPANISH FOOD MAP</p>
      <h1 class="font-serif font-bold text-white" style="font-size:clamp(28px,5vw,48px); margin-bottom:16px; line-height:1.25;">
        スペイン美食地図 — 味で旅するスペイン
      </h1>
      <p class="text-white/80" style="font-size:18px; max-width:640px; line-height:1.8; margin-bottom:40px;">
        50省・7つの美食ゾーンで探す、本場スペインのグルメ体験。<br />
        スペイン倶楽部が厳選したレストラン・バルマップ。
      </p>
      <a
        href="https://linktr.ee/supeinclub"
        target="_blank"
        rel="noopener nofollow noreferrer"
        class="bg-primary hover:bg-red-dark text-white font-bold rounded-lg transition-colors"
        style="padding:14px 28px; font-size:15px; text-decoration:none; display:inline-block;"
      >
        全マップをLinktreeで見る →
      </a>
    </div>
  </section>

  <!-- Content with TOC sidebar -->
  <div class="page-container" style="padding-top:48px; padding-bottom:80px;">
    <div class="content-grid">

      <div class="content-main">

        <details class="toc-mobile-inline">
          <summary>
            <span>目次</span>
            <span class="tmi-chevron" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>
          <ol class="tmi-list">
            {tocHeadings.map((h, i) => (
              <li>
                <a href={'#' + h.slug}>
                  <span class="tmi-num">{i + 1}.</span>
                  {h.text}
                </a>
              </li>
            ))}
          </ol>
        </details>

        <!-- Interactive SVG Map -->
        <section id="interactive-map" class="msec">
          <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:8px;">INTERACTIVE MAP</p>
          <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,36px); margin-bottom:12px;">スペイン州別マップ</h2>
          <p class="text-muted" style="font-size:16px; max-width:680px; line-height:1.7; margin-bottom:40px;">
            州をクリックして、レストランマップまたは詳細ガイドへ。赤い枠は編集部ガイドがある州です。
          </p>
          <SpainMapSVG />
        </section>

        <!-- 7 Zonas Culinarias -->
        <section id="culinary-zones" class="msec">
          <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:8px;">RUTAS DE SABOR</p>
          <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,36px); margin-bottom:12px;">7つの美食ゾーンで探す</h2>
          <p class="text-muted" style="font-size:16px; max-width:680px; line-height:1.7; margin-bottom:48px;">
            スペインは地域によって料理文化がまったく異なります。<br />
            まずあなたが好きな味のゾーンから探してみましょう。
          </p>

          <div class="zones-grid">
            {zones.map((zone) => {
              const Icon = zone.icon;
              return (
                <div class="zone-card" style={`border-left-color: ${zone.color};`}>
                  <div class="zone-header">
                    <div class="zone-icon" style={`color: ${zone.color};`}>
                      <Icon size={22} />
                    </div>
                    <div>
                      <h3 class="text-navy font-bold" style="font-size:17px; margin:0 0 4px;">{zone.title}</h3>
                      <div class="province-chips">
                        {zone.provincias.split(' · ').map((p) => (
                          <span class="province-chip">{p}</span>
                        ))}
                      </div>
                    </div>
                  </div>

                  <p class="text-muted" style="font-size:14px; font-style:italic; margin:12px 0 10px; line-height:1.6;">{zone.destacado}</p>

                  <div style="margin-bottom:16px;">
                    <span class="dish-badge">{zone.platoIconico}</span>
                  </div>

                  {zone.guideLink && (
                    <div style="margin-bottom:12px;">
                      <a href={zone.guideLink.href} class="guide-link-badge">
                        ガイドあり — {zone.guideLink.label} →
                      </a>
                    </div>
                  )}

                  <div class="province-links">
                    {zone.links.map((link) => (
                      <a href={link.url} target="_blank" rel="noopener noreferrer" class="province-map-link">
                        <MapPin size={11} />
                        {link.nameJa}
                      </a>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </section>

        <!-- Reloj gastronómico -->
        <section id="timing" class="msec">
          <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:8px;">TIMING IS EVERYTHING</p>
          <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,36px); margin-bottom:12px;">スペインの食事時間を知ろう</h2>
          <p class="text-muted" style="font-size:16px; margin-bottom:48px;">日本との時間差に注意。スペインの食生活は日本とまったく異なります。</p>

          <div class="timeline-wrap">
            {mealtimes.map((meal, i) => (
              <div class={`timeline-item${meal.highlight ? ' timeline-item--highlight' : ''}`}>
                <div class="timeline-dot"></div>
                <div class="timeline-time">{meal.time}</div>
                <div class="timeline-name font-bold">{meal.name}</div>
                <div class="timeline-desc">{meal.desc}</div>
              </div>
            ))}
          </div>

          <div class="alert-card" style="margin-top:40px;">
            <p style="margin:0; font-size:15px; line-height:1.7;">
              <strong>注意：</strong>スペインのレストランは通常13:30〜15:30と20:30〜22:30のみ営業。
              この時間以外は閉まっていることが多いです。
              お腹が空いたらバルでタパスを！
            </p>
          </div>
        </section>

        <!-- Japan maps -->
        <section id="japan-map" class="msec msec--last">
          <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:8px;">IN JAPAN</p>
          <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,36px); margin-bottom:12px;">日本のスペイン料理店マップ</h2>
          <p class="text-muted" style="font-size:16px; margin-bottom:32px;">日本全国のスペイン料理レストラン・バルをエリア別に検索</p>

          <div style="display:flex; flex-wrap:wrap; gap:12px; margin-bottom:32px;">
            <a href="/food/restaurants-tokyo/" class="japan-highlight-link">東京のスペイン料理店 →</a>
            <a href="/food/restaurants-osaka/" class="japan-highlight-link">大阪のスペイン料理店 →</a>
          </div>

          <div class="japan-grid">
            {japanMaps.map((j) => (
              <a href={j.url} target="_blank" rel="noopener noreferrer" class="japan-card">
                <p class="province-name-ja">{j.nameJa}</p>
                <p class="province-name-es">{j.name}</p>
              </a>
            ))}
          </div>
        </section>

      </div>

      <aside class="content-sidebar">
        <TOC headings={tocHeadings} />
      </aside>

    </div>
  </div>

  <!-- CTA — full-width -->
  <section class="bg-navy text-white" style="padding:72px 0; text-align:center;">
    <div class="container" style="max-width:640px;">
      <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:12px;">ALL MAPS</p>
      <h2 class="font-serif font-bold text-white" style="font-size:clamp(24px,3vw,32px); margin-bottom:16px;">全50省・日本全国のマップを見る</h2>
