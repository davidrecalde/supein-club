---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import TOC from '../../../components/TOC.astro';
import LineBanner from '../../../components/LineBanner.astro';
import SpainMapSVG from '../../../components/SpainMapSVG.astro';
import { Waves, Fish, UtensilsCrossed, Sun, Flame, Leaf, Anchor, MapPin } from 'lucide-astro';

const canonical = 'https://supein.club/food/spain-map/';
const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'スペイン料理', url: '/food/' },
  { name: 'スペイン美食マップ', url: '' },
];

const tocHeadings = [
  { depth: 2, slug: 'interactive-map', text: 'インタラクティブマップ' },
  { depth: 2, slug: 'culinary-zones',  text: '7つの美食ゾーン' },
  { depth: 2, slug: 'timing',          text: 'スペインの食事時間' },
  { depth: 2, slug: 'japan-map',       text: '日本のスペイン料理店' },
];

const entries = await getCollection('spain-map', ({ data }) => data.draft !== true);
const guideMap = new Map(entries.map((e) => [e.data.province.toLowerCase(), e]));

function hasGuide(provinceName: string) {
  const slug = provinceName.toLowerCase().replace(/\s+/g, '-').replace(/[áàä]/g, 'a').replace(/[éèê]/g, 'e').replace(/[íìî]/g, 'i').replace(/[óòô]/g, 'o').replace(/[úùû]/g, 'u').replace(/[ñ]/g, 'n');
  return guideMap.has(slug) ? guideMap.get(slug) : null;
}

type ZoneProvince = { nameJa: string; name: string; url: string };
type Zone = {
  color: string;
  icon: any;
  title: string;
  provincias: string;
  destacado: string;
  platoIconico: string;
  guideLink?: { href: string; label: string };
  links: ZoneProvince[];
};

