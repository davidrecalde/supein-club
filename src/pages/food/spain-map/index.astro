---
<BaseLayout title="スペイン フードマップ | supein.club">
  <SEO
    slot="seo"
    title="スペイン フードマップ — 全50省のレストラン・バルマップ | supein.club"
    description="スペイン倶楽部が厳選した50省のレストラン・バルマップ。スペイン旅行前の下調べから、日本のスペイン料理店探しまで。マドリード・バルセロナ・セビリアなど省別グルメガイドも。"
    canonical={canonical}
    breadcrumbs={breadcrumbs}
  />

  <!-- Hero -->
  <section class="bg-navy text-white relative" style="padding:80px 0;">
    <div class="absolute top-0 left-0 right-0 h-[3px] bg-primary"></div>
    <div class="container">
      <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:12px;">SPANISH FOOD MAP</p>
      <h1 class="font-serif font-bold text-white" style="font-size:clamp(32px,5vw,52px); margin-bottom:20px;">スペイン フードマップ</h1>
      <p class="text-white/80" style="font-size:18px; max-width:620px; line-height:1.7; margin-bottom:40px;">
        スペイン倶楽部が厳選した50省のレストラン・バルマップ。
        スペイン旅行前の下調べから、日本のスペイン料理店探しまで。
      </p>
      <a
        href="https://linktr.ee/supeinclub"
        target="_blank"
        rel="noopener nofollow noreferrer"
        class="bg-primary hover:bg-red-dark text-white font-bold rounded-lg transition-colors"
        style="padding:14px 28px; font-size:15px; text-decoration:none; display:inline-block;"
      >
        全マップをLinktreeで見る →
      </a>
    </div>
  </section>

  <!-- Editorial guides -->
  {entries.length > 0 && (
    <section class="bg-white" style="padding:72px 0;">
      <div class="container">
        <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:8px;">EDITORIAL GUIDES</p>
        <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,36px); margin-bottom:12px;">省別グルメガイド</h2>
        <p class="text-muted" style="font-size:16px; margin-bottom:48px;">スペイン倶楽部編集部が実際に訪れ、厳選したレストラン情報</p>
        <div class="editorial-grid">
          {entries.map((entry) => (
            <a href={`/food/${entry.data.province}-restaurants/`} class="editorial-card">
              <span class="region-chip">{entry.data.region}</span>
              <h3 class="text-navy font-bold" style="font-size:20px; margin:12px 0 6px;">{entry.data.provinceJa}</h3>
              <p class="text-muted" style="font-size:14px; margin:0 0 16px;">{entry.data.mainDish}</p>
              <span class="text-primary font-semibold" style="font-size:14px;">ガイドを読む →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- All 50 provinces -->
  <section style="background:var(--color-canvas); padding:72px 0;">
    <div class="container">
      <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:8px;">ALL MAPS</p>
      <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,36px); margin-bottom:12px;">スペイン全50省のマップ</h2>
      <p class="text-muted" style="font-size:16px; margin-bottom:48px;">各省のGoogleマップで本場のレストラン・バルを探す</p>
      <div class="provinces-grid">
        {provinces.map((p) => {
          const slug = p.name.toLowerCase().replace(/\s+/g, '-').replace(/[áàä]/g, 'a').replace(/[éèê]/g, 'e').replace(/[íìî]/g, 'i').replace(/[óòô]/g, 'o').replace(/[úùû]/g, 'u').replace(/[ñ]/g, 'n');
          const guide = guideMap.get(slug);
          if (guide) {
            return (
              <a href={`/food/${guide.data.province}-restaurants/`} class="province-card province-card--guide">
                <span class="guide-badge">ガイドあり</span>
                <p class="province-name-ja">{p.nameJa}</p>
                <p class="province-name-es">{p.name}</p>
                <span class="region-tag">{p.region}</span>
              </a>
            );
          }
          return (
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="province-card">
              <p class="province-name-ja">{p.nameJa}</p>
              <p class="province-name-es">{p.name}</p>
              <span class="region-tag">{p.region}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Japan maps -->
  <section class="bg-white" style="padding:72px 0;">
    <div class="container">
      <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:8px;">IN JAPAN</p>
      <h2 class="font-serif font-bold text-navy" style="font-size:clamp(24px,3vw,36px); margin-bottom:12px;">日本のスペイン料理店マップ</h2>
      <p class="text-muted" style="font-size:16px; margin-bottom:32px;">日本全国のスペイン料理レストラン・バルをエリア別に検索</p>

      <div style="display:flex; flex-wrap:wrap; gap:12px; margin-bottom:32px;">
        <a href="/food/restaurants-tokyo/" class="japan-highlight-link">東京のスペイン料理店 →</a>
        <a href="/food/restaurants-osaka/" class="japan-highlight-link">大阪のスペイン料理店 →</a>
      </div>

      <div class="japan-grid">
        {japanMaps.map((j) => (
          <a href={j.url} target="_blank" rel="noopener noreferrer" class="japan-card">
            <p class="province-name-ja">{j.nameJa}</p>
            <p class="province-name-es" style="font-size:11px;">{j.name}</p>
          </a>
        ))}
      </div>

      <div style="margin-top:40px; text-align:center;">
        <a
          href="https://linktr.ee/supeinclub"
          target="_blank"
          rel="noopener nofollow noreferrer"
          class="bg-navy hover:bg-navy-deep text-white font-bold rounded-lg transition-colors"
          style="padding:14px 28px; font-size:15px; text-decoration:none; display:inline-block;"
        >
          全マップをLinktreeで一覧表示
        </a>
      </div>
    </div>
  </section>

  <LineBanner />
</BaseLayout>

<style>
  .editorial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .editorial-card {
    display: block;
    padding: 24px;
    border: 2px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .editorial-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }
  .region-chip {
    display: inline-block;
    background: #C8102E1A;
    color: var(--color-primary);
    font-size: 11px;
    font-weight: 600;
    border-radius: 4px;
    padding: 3px 10px;
  }
  .provinces-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
  }
  .province-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    background: white;
    transition: border-color 0.2s;
    position: relative;
  }
  .province-card:hover {
    border-color: var(--color-muted);
  }
  .province-card--guide {
    background: var(--color-navy);
    border-color: var(--color-primary);
  }
  .province-card--guide .province-name-ja {
    color: white;
  }
  .province-card--guide .province-name-es {
    color: rgba(255,255,255,0.6);
  }
  .province-card--guide .region-tag {
    color: rgba(255,255,255,0.5);
  }
  .province-name-ja {
    font-weight: 700;
    font-size: 14px;
    color: var(--color-navy);
    margin: 0;
  }
  .province-name-es {
    font-size: 11px;
    color: var(--color-muted);
    margin: 0;
  }
  .region-tag {
    font-size: 10px;
    color: var(--color-muted);
    margin: 0;
  }
  .guide-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    background: var(--color-primary);
    color: white;
    font-size: 9px;
    font-weight: 700;
    border-radius: 4px;
    padding: 2px 6px;
  }
  .japan-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
  }
  .japan-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    background: var(--color-canvas);
    transition: border-color 0.2s;
  }
  .japan-card:hover {
    border-color: var(--color-primary);
  }
  .japan-highlight-link {
    display: inline-block;
    padding: 10px 20px;
    background: var(--color-navy);
    color: white;
    font-weight: 700;
    font-size: 14px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .japan-highlight-link:hover {
    background: var(--color-navy-deep);
  }
  @media (max-width: 1023px) {
    .editorial-grid { grid-template-columns: repeat(2, 1fr); }
    .provinces-grid { grid-template-columns: repeat(4, 1fr); }
    .japan-grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 767px) {
    .editorial-grid { grid-template-columns: repeat(2, 1fr); }
    .provinces-grid { grid-template-columns: repeat(3, 1fr); }
    .japan-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 479px) {
    .editorial-grid { grid-template-columns: 1fr; }
    .provinces-grid { grid-template-columns: repeat(2, 1fr); }
    .japan-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
