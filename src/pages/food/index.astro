---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import PillarHero from '../../components/PillarHero.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import LineBanner from '../../components/LineBanner.astro';
import AdSlot from '../../components/AdSlot.astro';

const articles = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'food');
const sorted = articles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const clusters = [
  { href: '/food/paella/', label: 'パエリア' },
  { href: '/food/tapas/', label: 'タパス' },
  { href: '/food/spanish-wine/', label: 'スペインワイン' },
  { href: '/food/olive-oil/', label: 'オリーブオイル' },
  { href: '/food/souvenirs/', label: 'お土産' },
  { href: '/food/restaurants-tokyo/', label: '東京のお店' },
  { href: '/food/restaurants-osaka/', label: '大阪のお店' },
];

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'スペイン料理', url: '/food/' },
];
---
<BaseLayout>
  <SEO
    slot="seo"
    title="スペイン料理 完全ガイド | supein.club"
    description="パエリア・タパス・ワイン・オリーブオイルなどスペイン料理の基本から応用まで。東京・大阪のスペイン料理レストラン情報も。"
    canonical="https://supein.club/food/"
    breadcrumbs={breadcrumbs}
  />
  <PillarHero
    title="スペイン料理"
    description="パエリア、タパス、ワイン——スペインの豊かな食文化をレシピから東京・大阪のレストランまでご紹介します。"
  />
  <section class="max-w-5xl mx-auto px-5 py-14">
    <h2 class="font-sans font-bold text-xl text-navy mb-5">カテゴリ</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 mb-12">
      {clusters.map(({ href, label }) => (
        <a href={href} class="bg-white rounded-lg px-3 py-3 min-h-[44px] flex items-center justify-center text-center border border-[#E8E8E6] hover:border-primary/30 hover:shadow-sm transition-all">
          <span class="font-semibold text-navy text-xs leading-snug block">{label}</span>
        </a>
      ))}
    </div>
    <div class="mb-10">
      <AdSlot
        position="pillar-mid"
        interlinkTitle="本格パエリアの作り方：魚介パエリアレシピ完全版"
        interlinkUrl="/food/paella/"
        interlinkPillar="スペイン料理"
        interlinkReadingTime={5}
      />
    </div>
    {sorted.length > 0 && (
      <>
        <h2 class="font-sans font-bold text-xl text-navy mb-5">記事一覧</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {sorted.map((a) => {
            const parts = a.id.replace(/\.(md|mdx)$/, '').split('/');
            const slug = parts[2] ?? a.data.cluster;
            return (
              <ArticleCard title={a.data.title} description={a.data.description} href={`/food/${a.data.cluster}/${slug}/`} pillar="food" image={a.data.image} imageAlt={a.data.imageAlt} pubDate={a.data.pubDate} />
            );
          })}
        </div>
      </>
    )}
  </section>
  <!-- SECCIÓN A — Spanish Food Map -->
  <section style="background:#002147; padding:72px 0;">
    <div class="container">
      <div class="food-map-grid">
        <div>
          <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:12px;">SPANISH FOOD MAP</p>
          <h2 class="font-serif font-bold text-white" style="font-size:clamp(26px,3vw,36px); margin-bottom:20px;">スペイン美食マップ</h2>
          <p class="text-white/80" style="font-size:17px; line-height:1.8; margin-bottom:32px;">
            スペイン倶楽部が厳選した50省のレストラン・バルマップ。<br />
            スペイン旅行の下調べから、地元グルメの発掘まで。<br />
            全マップは無料でご覧いただけます。
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:12px;">
            <a
              href="/food/spain-map/"
              class="bg-primary hover:bg-red-dark text-white font-bold rounded-lg transition-colors"
              style="padding:14px 28px; font-size:15px; text-decoration:none; display:inline-block;"
            >
              マップを探索する →
            </a>
            <a
              href="https://linktr.ee/supeinclub"
              target="_blank"
              rel="noopener nofollow noreferrer"
              class="text-white font-bold rounded-lg transition-colors"
              style="padding:14px 28px; font-size:15px; text-decoration:none; display:inline-block; border:2px solid rgba(255,255,255,0.6);"
            >
              Linktreeで全マップ
            </a>
          </div>
        </div>
        <div class="food-map-cards">
          {[
            { nameJa: 'バスク地方', desc: 'ピンチョス・ミシュラン', href: '/food/pais-vasco-restaurants/' },
            { nameJa: 'マドリード', desc: 'タパス・コシード', href: '/food/madrid-restaurants/' },
            { nameJa: 'バルセロナ', desc: 'パエリア・カタルーニャ', href: '/food/barcelona-restaurants/' },
            { nameJa: 'セビリア', desc: 'ガスパチョ・シェリー', href: '/food/sevilla-restaurants/' },
          ].map(({ nameJa, desc, href }) => (
            <a href={href} class="food-mini-card">
              <p class="text-white font-bold" style="font-size:15px; margin:0 0 6px;">{nameJa}</p>
              <p class="text-white/70" style="font-size:13px; margin:0;">{desc}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN B — Guía culinaria del viajero -->
  <section style="background:var(--color-canvas); padding:72px 0;">
    <div class="container" style="max-width:800px; text-align:center;">
      <p class="text-primary font-bold tracking-widest" style="font-size:11px; text-transform:uppercase; margin-bottom:12px;">COMING SOON</p>
      <h2 class="font-serif font-bold text-navy" style="font-size:clamp(20px,2.5vw,28px); margin-bottom:12px;">旅行者の為のスペイン料理とワインガイドブック</h2>
      <p class="text-primary font-bold" style="font-size:16px; margin-bottom:20px;">西和/和西辞典</p>
      <p class="text-muted" style="font-size:16px; line-height:1.8; max-width:560px; margin:0 auto 32px;">
        スペイン料理とワインを日本語で深く理解するための総合ガイド。
        レストランでの注文から、ワイン選びまで。現在制作中です。
      </p>
      <a
        href="/food/traveler-guide-to-spanish-cuisine-and-wine/"
        class="text-navy font-bold transition-colors"
        style="padding:14px 28px; font-size:15px; text-decoration:none; display:inline-block; border:2px solid var(--color-navy); border-radius:6px;"
      >
        ガイドブックの詳細を見る →
      </a>
    </div>
  </section>

  <LineBanner />
</BaseLayout>

<style>
  .food-map-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .food-map-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .food-mini-card {
    display: block;
    padding: 16px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .food-mini-card:hover {
    border-color: var(--color-primary);
  }
  @media (max-width: 1023px) {
    .food-map-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 479px) {
    .food-map-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
