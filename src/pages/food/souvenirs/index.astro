---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import LineBanner from '../../../components/LineBanner.astro';

const articles = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'food' && data.cluster === 'souvenirs');
const sorted = articles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'スペイン料理', url: '/food/' },
  { name: 'スペインお土産', url: '/food/souvenirs/' },
];
---
<BaseLayout>
  <SEO slot="seo" title="スペイン お土産 おすすめ人気ランキング | supein.club" description="スペイン旅行で絶対買いたいおすすめお土産。チョコレート・ワイン・オリーブオイル・食器など喜ばれるギフト完全ガイド。" canonical="https://supein.club/food/souvenirs/" breadcrumbs={breadcrumbs} />
  <section class="bg-navy text-white py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <Breadcrumb items={breadcrumbs} dark />
      <h1 class="font-serif text-3xl md:text-4xl font-bold leading-tight mt-4">スペイン お土産 おすすめガイド</h1>
      <p class="text-white/80 text-lg mt-3 max-w-2xl">友人・家族に喜ばれるスペイン土産を厳選。食品から雑貨まで予算別におすすめ品を紹介。</p>
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-4 py-12">
    {sorted.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {sorted.map((a) => {
          const parts = a.id.replace(/\.(md|mdx)$/, '').split('/');
          const slug = parts[2] ?? a.data.cluster;
          return <ArticleCard title={a.data.title} description={a.data.description} href={`/food/souvenirs/${slug}/`} pillar="food" image={a.data.image} imageAlt={a.data.imageAlt} pubDate={a.data.pubDate} />;
        })}
      </div>
    ) : (
      <p class="text-muted text-center py-12">記事を準備中です。近日公開予定。</p>
    )}
  </section>
  <LineBanner />
</BaseLayout>
