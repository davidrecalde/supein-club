---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: 'プライバシーポリシー', url: '/privacy/' },
];
---
<BaseLayout>
  <SEO slot="seo" title="プライバシーポリシー | スペイン倶楽部" description="supein.club・スペイン倶楽部のプライバシーポリシー。" canonical="https://supein.club/privacy/" breadcrumbs={breadcrumbs} />
  <section class="bg-navy text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-serif text-4xl font-bold mb-4">プライバシーポリシー</h1>
      <p class="text-white/80 text-lg">個人情報の取り扱いについて</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-white rounded-2xl shadow-sm border border-ink/5 p-8">
      <p class="text-muted leading-relaxed">このページは現在準備中です。</p>
    </div>
  </section>
</BaseLayout>
